  <!-- ============================================================ -->
  <!-- SHARED SELECTION ENTRIES                                     -->
  <!-- Wargear and weapons available to link into unit entries.     -->
  <!-- ============================================================ -->
  <sharedSelectionEntries>

    <!-- ── ARMOUR ───────────────────────────────────────────────── -->

    <selectionEntry id="la-gear-runearmour" name="Rune Armour" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-runearmour" name="Rune Armour"
          description="Rune Armour confers a 4+ Invulnerable Save."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="la-gear-mesharmour" name="Mesh Armour" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-mesharmour" name="Mesh Armour"
          description="Mesh Armour confers a 5+ Armour Save."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="la-gear-heavymesharmour" name="Heavy Mesh Armour" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-heavymesharmour" name="Heavy Mesh Armour"
          description="Heavy Mesh Armour confers a 4+ Armour Save."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="la-gear-aspectarmour" name="Aspect Armour" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-aspectarmour" name="Aspect Armour"
          description="Aspect Armour confers a 4+ Armour Save and a 5+ Invulnerable Save."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="la-gear-heavyaspectarmour" name="Heavy Aspect Armour" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-heavyaspectarmour" name="Heavy Aspect Armour"
          description="Heavy Aspect Armour confers a 3+ Armour Save and a 5+ Invulnerable Save."/>
      </rules>
    </selectionEntry>

    <!-- ── SHIELDS / INVULNERABLES ──────────────────────────────── -->

    <selectionEntry id="la-gear-forceshield" name="Forceshield" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-forceshield" name="Forceshield"
          description="A Forceshield confers a 5+ Invulnerable Save."/>
      </rules>
    </selectionEntry>

    <!-- ── GRENADES ─────────────────────────────────────────────── -->

    <selectionEntry id="la-gear-plasmagrenades" name="Plasma Grenades" type="upgrade" hidden="false">
      <rules>
        <rule id="la-rule-plasmagrenades" name="Plasma Grenades"
          description="A unit that includes at least one model with Plasma Grenades makes attacks at its normal Initiative Step during an Assault after Charging through Difficult or Dangerous Terrain. In addition the Controlling Player may choose to have a model in base contact during the Assault phase with a Building, Fortification, Vehicle, Dreadnought or Automata inflict one automatic Str 5, AP 4 Hit with Breaching (6+) at Initiative Step 1."/>
      </rules>
    </selectionEntry>

    <!-- ── WEAPONS — RANGED ──────────────────────────────────────── -->

    <selectionEntry id="la-gear-shurikencat" name="Shuriken Catapult" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-shurikencat-pe" name="Shuriken Catapult" typeId="la-pt-ranged" profileId="la-wp-shurikencat-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-avengercatapult" name="Avenger Catapult" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-avengercatapult-pe" name="Avenger Catapult" typeId="la-pt-ranged" profileId="la-wp-avengercatapult-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-tl-avengercatapult" name="Twin-Linked Avenger Catapult" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-tl-avengercatapult-pe" name="Twin-Linked Avenger Catapult" typeId="la-pt-ranged" profileId="la-wp-tl-avengercatapult-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-shurikencan" name="Shuriken Cannon" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-shurikencan-pe" name="Shuriken Cannon" typeId="la-pt-ranged" profileId="la-wp-shurikencan-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-scatlaser" name="Scatter Laser" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-scatlaser-pe" name="Scatter Laser" typeId="la-pt-ranged" profileId="la-wp-scatlaser-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-brightlance" name="Bright Lance" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-brightlance-pe" name="Bright Lance" typeId="la-pt-ranged" profileId="la-wp-brightlance-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-starcannon" name="Starcannon" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-starcannon-pe" name="Starcannon" typeId="la-pt-ranged" profileId="la-wp-starcannon-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-aml" name="Aeldari Missile Launcher (Sunburst, Starshot)" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-aml-sunburst-pe" name="Aeldari Missile Launcher (Sunburst)" typeId="la-pt-ranged" profileId="la-wp-aml-sunburst-p"/>
        <profile id="la-wp-aml-starshot-pe" name="Aeldari Missile Launcher (Starshot)" typeId="la-pt-ranged" profileId="la-wp-aml-starshot-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-shurikenpistol" name="Shuriken Pistol" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-shurikenpistol-pe" name="Shuriken Pistol" typeId="la-pt-ranged" profileId="la-wp-shurikenpistol-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-singingspear" name="Singing Spear" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-singingspear-r-pe" name="Singing Spear (Ranged)" typeId="la-pt-ranged" profileId="la-wp-singingspear-r-p"/>
        <profile id="la-wp-singingspear-m-pe" name="Singing Spear (Melee)"  typeId="la-pt-melee"  profileId="la-wp-singingspear-m-p"/>
      </profiles>
    </selectionEntry>

    <!-- ── WEAPONS — MELEE ───────────────────────────────────────── -->

    <selectionEntry id="la-gear-witchwpn" name="Witch Weapon" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-witchwpn-pe" name="Witch Weapon" typeId="la-pt-melee" profileId="la-wp-witchwpn-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-ccw" name="Close Combat Weapon" type="upgrade" hidden="false">
      <profiles>
        <profile id="la-wp-ccw-pe" name="Close Combat Weapon" typeId="la-pt-melee" profileId="la-wp-ccw-p"/>
      </profiles>
    </selectionEntry>

    <!-- ── MISC UPGRADES ─────────────────────────────────────────── -->

    <selectionEntry id="la-gear-auguryscanner" name="Augury Scanner" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="10"/>
      </costs>
      <rules>
        <rule id="la-rule-auguryscanner" name="Augury Scanner"
          description="Enemy models cannot be deployed using Infiltrate within 18&quot; of a model with an Augury Scanner. The unit ignores the 24&quot; Night Fighting line of sight limit when shooting. When any enemy unit is deployed from Reserves, the unit may make an Interceptor Reaction without expending a Reaction Allotment point (once per Phase)."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="la-gear-commbeard" name="Comm-Bead" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="10"/>
      </costs>
      <rules>
        <rule id="la-rule-commbead" name="Comm-Bead"
          description="While at least one model with a Comm-Bead is on the battlefield and not Embarked, the Controlling Player may re-roll any Scatter rolls (weapon or deployment) if the model has line of sight to the target. In addition, a unit with a Comm-Bead ignores the -1 Leadership penalty from Night Fighting."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="la-gear-craftstandard" name="Craftworld Standard" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="10"/>
      </costs>
      <rules>
        <rule id="la-rule-craftstandard" name="Craftworld Standard"
          description="A unit with a Craftworld Standard adds +1 to the Wounds score when determining combat result. In addition, the unit may choose to Fall Back only D6&quot; instead of 2D6&quot; (or 3D6&quot; for Cavalry), and models that would move off the battlefield edge stop 1&quot; from it instead."/>
      </rules>
    </selectionEntry>

    <!-- Defender Platform weapon upgrade (for Guardian Defender) -->
    <selectionEntry id="la-gear-defplat-scat" name="Scatter Laser (Platform)" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="5"/>
      </costs>
      <profiles>
        <profile id="la-wp-scatlaser-plat" name="Scatter Laser" typeId="la-pt-ranged" profileId="la-wp-scatlaser-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-defplat-starcannon" name="Starcannon (Platform)" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="10"/>
      </costs>
      <profiles>
        <profile id="la-wp-starcannon-plat" name="Starcannon" typeId="la-pt-ranged" profileId="la-wp-starcannon-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-defplat-aml" name="Aeldari Missile Launcher (Platform)" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="10"/>
      </costs>
      <profiles>
        <profile id="la-wp-aml-plat-sun" name="Aeldari Missile Launcher (Sunburst)" typeId="la-pt-ranged" profileId="la-wp-aml-sunburst-p"/>
        <profile id="la-wp-aml-plat-shot" name="Aeldari Missile Launcher (Starshot)" typeId="la-pt-ranged" profileId="la-wp-aml-starshot-p"/>
      </profiles>
    </selectionEntry>

    <selectionEntry id="la-gear-defplat-brightlance" name="Bright Lance (Platform)" type="upgrade" hidden="false">
      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="15"/>
      </costs>
      <profiles>
        <profile id="la-wp-brightlance-plat" name="Bright Lance" typeId="la-pt-ranged" profileId="la-wp-brightlance-p"/>
      </profiles>
    </selectionEntry>

  </sharedSelectionEntries>

  <!-- ============================================================ -->
  <!-- ROOT SELECTION ENTRIES (units available in army builder)     -->
