  </costTypes>

  <profileTypes>
    <profileType id="pt-unit" name="Unit">
      <characteristicTypes>
        <characteristicType id="ct-m"   name="Move"/>
        <characteristicType id="ct-ws"  name="WS"/>
        <characteristicType id="ct-bs"  name="BS"/>
        <characteristicType id="ct-s"   name="S"/>
        <characteristicType id="ct-t"   name="T"/>
        <characteristicType id="ct-w"   name="W"/>
        <characteristicType id="ct-i"   name="I"/>
        <characteristicType id="ct-a"   name="A"/>
        <characteristicType id="ct-ld"  name="Ld"/>
        <characteristicType id="ct-sv"  name="Save"/>
