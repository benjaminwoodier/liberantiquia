        <characteristicType id="ct-vbs"   name="BS"/>
        <characteristicType id="ct-vfront" name="Front"/>
        <characteristicType id="ct-vside"  name="Side"/>
        <characteristicType id="ct-vrear"  name="Rear"/>
        <characteristicType id="ct-vhp"   name="HP"/>
        <characteristicType id="ct-vcap"  name="Transport Capacity"/>
        <characteristicType id="ct-vut"   name="Unit Type"/>
      </characteristicTypes>
