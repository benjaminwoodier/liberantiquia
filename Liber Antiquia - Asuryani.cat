  </profileTypes>

  <categoryEntries>
    <categoryEntry id="cat-hq"        name="HQ"/>
    <categoryEntry id="cat-elites"    name="Elites"/>
    <categoryEntry id="cat-troops"    name="Troops"/>
    <categoryEntry id="cat-fa"        name="Fast Attack"/>
    <categoryEntry id="cat-hs"        name="Heavy Support"/>
    <categoryEntry id="cat-low"       name="Lords of War"/>
    <categoryEntry id="cat-fort"      name="Fortification"/>
    <categoryEntry id="cat-dt"        name="Dedicated Transport"/>
    <categoryEntry id="cat-primarch"  name="Dramatis Personae"/>
    <categoryEntry id="cat-asuryani"  name="Asuryani"/>
    <categoryEntry id="cat-character" name="Character"/>
    <categoryEntry id="cat-psyker"    name="Psyker"/>
    <categoryEntry id="cat-infantry"  name="Infantry"/>
    <categoryEntry id="cat-cavalry"   name="Cavalry"/>
    <categoryEntry id="cat-vehicle"   name="Vehicle"/>
    <categoryEntry id="cat-line"      name="Line"/>
    <categoryEntry id="cat-heavy"     name="Heavy"/>
    <categoryEntry id="cat-wraith"    name="Wraith"/>
    <categoryEntry id="cat-gravplat"  name="Grav-Platform"/>
    <categoryEntry id="cat-unique"    name="Unique"/>
    <categoryEntry id="cat-plord"     name="Phoenix Lord"/>
    <categoryEntry id="cat-skirmish"  name="Skirmish"/>
    <categoryEntry id="cat-mech"      name="Mechanised"/>
    <categoryEntry id="cat-antigrav"  name="Antigrav"/>
    <categoryEntry id="cat-flyer"     name="Flyer"/>
    <categoryEntry id="cat-titan"     name="Titan"/>
    <categoryEntry id="cat-superheavy" name="Super-Heavy"/>
    <categoryEntry id="cat-knight"    name="Knight"/>
    <categoryEntry id="cat-daemon"    name="Daemon Primarch"/>
    <categoryEntry id="cat-gargantuan" name="Gargantuan"/>
    <categoryEntry id="cat-automata"  name="Automata"/>
  </categoryEntries>


<sharedRules>
    <!-- Movement / Deployment -->
    <rule id="sr-fleet1"      name="Fleet (1)"             description="This unit may re-roll a single dice when determining Run or Charge distance."/>
    <rule id="sr-fleet2"      name="Fleet (2)"             description="This unit may re-roll up to two dice when determining Run or Charge distance."/>
    <rule id="sr-fleet3"      name="Fleet (3)"             description="This unit may re-roll up to three dice when determining Run or Charge distance."/>
    <rule id="sr-deepstrike"  name="Deep Strike"           description="This unit may be held in Reserve and arrive via Deep Strike Assault as per the core rulebook."/>
    <rule id="sr-infiltrate"  name="Infiltrate"            description="This unit may be set up using the Infiltrate deployment rules as per the core rulebook."/>
    <rule id="sr-scout"       name="Scout"                 description="This unit may make a Scout move before the first Game Turn as per the core rulebook."/>
    <rule id="sr-outflank"    name="Outflank"              description="When this unit arrives from Reserve, the controlling player may choose which long table edge it arrives from."/>
    <rule id="sr-skyleap"     name="Skyleap"               description="At the beginning of the Controlling Player's Movement phase, if this unit is not locked in combat, it may be placed back into ongoing Reserves and assigned to a Deep Strike Assault on the next player turn."/>
    <rule id="sr-skystrike"   name="Skystrike"             description="At the end of the Movement Phase, this unit makes one attack per model against an enemy unit with the Flyer Sub-type moved over this turn. Hits automatically on a 4+ at Str 4 AP4 with Haywire. Only one target per turn."/>
    <rule id="sr-skyhunter"   name="Skyhunter"             description="If this model chooses to move Flat Out, it moves up to triple its Movement Characteristic instead of double."/>
    <rule id="sr-heraldvic"   name="Herald of Victory"     description="A unit containing at least one model with this rule always counts as rolling a hit on the scatter die when performing a Deep Strike Assault."/>
    <rule id="sr-vectordance" name="Vector Dancer"         description="This flyer may make an additional 90 degree pivot at the end of its Movement in the Controlling Player's Movement Phase."/>

    <!-- Character / Command -->
    <rule id="sr-ic"          name="Independent Character" description="This model may join and leave units as per the Independent Character rules in the core rulebook."/>
    <rule id="sr-poc"         name="Path of Command"       description="If your army contains any models with this rule in the Primary Detachment, one must be your Warlord. Units from the same Detachment sharing the same Aspect Shrine (X) rule as the Warlord gain the Line sub-type."/>
    <rule id="sr-ewwarrior"   name="Eternal Warrior"       description="This model is immune to the Instant Death special rule."/>
    <rule id="sr-favkh"       name="Favoured of Khaine"    description="All units composed entirely of models with the Asuryani Sub-type which can draw line of sight to at least one model with this rule gain +1 to their Leadership (to a maximum of 10)."/>

    <!-- Morale / Psychology -->
    <rule id="sr-fearless"    name="Fearless"              description="This unit automatically passes Morale checks and Pinning tests, and may not choose to fail a Morale check."/>
    <rule id="sr-stubborn"    name="Stubborn"              description="This unit uses its unmodified Leadership when making Morale checks."/>
    <rule id="sr-fear1"       name="Fear (1)"              description="Enemy units in base contact with this unit must pass a Leadership test at -1 or suffer a -1 penalty to their WS for the duration of the Assault phase."/>
    <rule id="sr-fear2"       name="Fear (2)"              description="Enemy units in base contact with this unit must pass a Leadership test at -2 or suffer a -1 penalty to their WS for the duration of the Assault phase."/>
    <rule id="sr-ironresolve" name="Iron Resolve"          description="A unit containing one or more models with this rule automatically passes Pinning tests, Regroup tests, and Morale checks, and ignores the effects of the Fear special rule."/>
    <rule id="sr-soulforfeit" name="Soul Forfeit"          description="This model never awards Victory Points when slain and does not count toward units slain. This model is not a Scoring or Denial unit."/>

    <!-- Shooting -->
    <rule id="sr-relentless"  name="Relentless"            description="This unit may fire Heavy or Ordnance weapons and count as Stationary even if it moved in the preceding Movement phase."/>
    <rule id="sr-fastshot"    name="Fast Shot"             description="This model may add one to the number of shots fired when making a Shooting Attack with a weapon of the Heavy type."/>
    <rule id="sr-inescacc"    name="Inescapable Accuracy"  description="Successful Shrouded Damage Mitigation Rolls and Countermeasures Saves made against Shooting Attacks by this model must be re-rolled."/>
    <rule id="sr-crackshot"   name="Crack Shot"            description="This model may re-roll a single failed To-Hit, To-Wound, or Armour Penetration roll per turn."/>
    <rule id="sr-splitfire"   name="Split Fire"            description="One model in this unit may target a different enemy unit to the rest of the unit when shooting."/>
    <rule id="sr-firingp2"    name="Firing Protocols (2)"  description="Once per turn, this model may fire a second time with a single Assault or Pistol weapon at BS 1."/>
    <rule id="sr-firingp3"    name="Firing Protocols (3)"  description="Once per turn, this model may fire up to two additional times with Assault or Pistol weapons at BS 1."/>
    <rule id="sr-markkurnous" name="Mark of Kurnous"       description="At the start of the Shooting Phase, this unit may select an enemy unit within 12&quot;. The unit loses Firing Protocols (X) but gains Ignores Cover against the selected unit until the end of the Shooting Phase."/>
    <rule id="sr-skilledrider" name="Skilled Rider"        description="This model may run in the Movement Phase and still fire a single ranged weapon in the Shooting Phase at BS2. Cannot be improved by any source. If used, the unit may not benefit from Firing Protocols (X) this turn."/>
    <rule id="sr-ghostlight"  name="Ghostlight"            description="When a unit with multiple Ghostlight weapons shoots, they may combine fire: one model shoots, gaining bonuses for each two additional models with Ghostlight weapons (choose from: +6&quot; range, +1 Str, -1 AP, +1 shot)."/>
    <rule id="sr-linkedfire"  name="Linked Fire"           description="When a unit composed entirely of models with Linked Fire weapons shoots, they may combine fire: one model shoots, gaining bonuses for each additional model with a Linked Fire weapon."/>
    <rule id="sr-precshots4"  name="Precision Shots (4+)"  description="On a To-Hit roll of 4+, this model's shooting attacks may be allocated to any model in the target unit, including characters."/>
    <rule id="sr-precshots2"  name="Precision Shots (2+)"  description="On a To-Hit roll of 2+, this model's shooting attacks may be allocated to any model in the target unit, including characters."/>
    <rule id="sr-agile"       name="Agile"                 description="This model may re-roll failed Shrouded Damage Mitigation rolls."/>

    <!-- Assault -->
    <rule id="sr-hitrun"      name="Hit and Run"           description="This unit may make a Hit and Run move as per the core rulebook."/>
    <rule id="sr-hamwrath1"   name="Hammer of Wrath (1)"   description="Each model makes 1 additional automatic hit at unmodified Strength with no AP when making a successful Charge."/>
    <rule id="sr-hamwrath2"   name="Hammer of Wrath (2)"   description="Each model makes 2 additional automatic hits at unmodified Strength with no AP when making a successful Charge."/>
    <rule id="sr-hamwrath3"   name="Hammer of Wrath (3)"   description="Each model makes 3 additional automatic hits at unmodified Strength with no AP when making a successful Charge."/>
    <rule id="sr-furcharge1"  name="Furious Charge (1)"    description="This unit gains +1 Strength on a turn in which it charges."/>
    <rule id="sr-furcharge2"  name="Furious Charge (2)"    description="This unit gains +2 Strength on a turn in which it charges."/>
    <rule id="sr-counter1"    name="Counter-Attack (1)"    description="If this unit is charged, it may make 1 additional attack in the ensuing Assault phase."/>
    <rule id="sr-rage2"       name="Rage (2)"              description="This unit gains +2 Attacks on any turn in which it charges."/>
    <rule id="sr-crusader"    name="Crusader"              description="This unit may re-roll the dice when determining Run and Charge distances."/>
    <rule id="sr-acrobatic"   name="Acrobatic"             description="A unit entirely composed of models with this rule that chooses to Run may still declare a Charge. Models attack at normal Initiative after charging through Difficult or Dangerous Terrain (but still suffer charge roll penalties)."/>
    <rule id="sr-warshout"    name="War Shout"             description="On a turn in which a unit containing this model charges or is successfully charged, all enemy models locked in combat suffer -1 to their Weapon Skill (minimum 1)."/>
    <rule id="sr-brutambush"  name="Brutal Ambush"         description="This unit has Shrouded (5+) until the first time it is locked in combat, at which point it loses Shrouded (5+) and gains Rage (2) and Counter-Attack (1)."/>
    <rule id="sr-stalker"     name="Stalker"               description="During the first round of a Challenge, this model gains bonus attacks equal to the amount its Initiative is higher than the opposing model's. No effect if Initiative is equal or lower."/>
    <rule id="sr-wrecker"     name="Wrecker"               description="Penetrating Hits caused by this model add +1 to rolls on the Vehicle or Building Damage tables."/>
    <rule id="sr-monsterhunt" name="Monster Hunter"        description="This model has the Armourbane (Ranged) and Armourbane (Melee) special rules against models with the Monstrous Creature or Gargantuan Creature unit type."/>
    <rule id="sr-precstrikes2" name="Precision Strikes (2+)" description="On a To-Hit roll of 2+, this model's melee attacks may be allocated to any model in the target unit, including characters."/>
    <rule id="sr-precstrikes5" name="Precision Strikes (5+)" description="On a To-Hit roll of 5+, this model's melee attacks may be allocated to any model in the target unit, including characters."/>
    <rule id="sr-disarmstrike" name="Disarming Strike"     description="Before rolling to Hit in a Challenge, nominate one of the opponent's melee weapons. Both models roll D6+WS; highest wins. If opponent wins, Jain Zar loses 3 Attacks this phase. If Jain Zar wins, she loses 1 Attack but the opponent loses the nominated weapon this phase."/>

    <!-- Defences / Saves -->
    <rule id="sr-shroud4"     name="Shrouded (4+)"         description="Models in this unit may take a 4+ Damage Mitigation roll against any Wound or Hull Point of damage suffered."/>
    <rule id="sr-shroud5"     name="Shrouded (5+)"         description="Models in this unit may take a 5+ Damage Mitigation roll against any Wound or Hull Point of damage suffered."/>
    <rule id="sr-shroud6"     name="Shrouded (6+)"         description="Models in this unit may take a 6+ Damage Mitigation roll against any Wound or Hull Point of damage suffered."/>
    <rule id="sr-fnp5"        name="Feel No Pain (5+)"     description="Models in this unit may take a 5+ Feel No Pain roll against any Wound not caused by Instant Death."/>
    <rule id="sr-itwillnotdie5" name="It Will Not Die (5+)" description="At the end of each player turn, this model rolls a D6. On a 5+, it regains one lost Wound."/>
    <rule id="sr-itwillnotdie6" name="It Will Not Die (6+)" description="At the end of each player turn, this model rolls a D6. On a 6+, it regains one lost Wound."/>
    <rule id="sr-aw3"         name="Adamantium Will (3+)"  description="Enemy Psykers within 18&quot; must reduce their Leadership by -3 when making Psychic Checks. This model gains a 3+ save against Psychic Powers targeting it."/>
    <rule id="sr-bh1"         name="Battle-Hardened (1)"   description="This unit may re-roll a single To Hit roll per phase."/>
    <rule id="sr-sunsbrill"   name="Sun's Brilliance"      description="Shooting attacks targeting a unit containing a model with this rule made as part of an Interceptor Reaction are resolved as Snap Shots. Models immune to Blind are unaffected."/>

    <!-- Movement special -->
    <rule id="sr-mtc"         name="Move Through Cover"    description="When this unit moves through Difficult Terrain, it rolls an extra D6 and discards the lowest result."/>
    <rule id="sr-pathfinder"  name="Pathfinder"            description="This unit treats all Difficult Terrain as Open Terrain when moving, and does not suffer Initiative penalties when charging through Difficult or Dangerous Terrain."/>
    <rule id="sr-flickerjump" name="Flickerjump"           description="Advanced Reaction: When targeted by a Shooting Attack, this unit may immediately move 2D6&quot; in any direction before the attack is resolved. On a double 1, one model is removed as a casualty. If the attack is no longer valid after the move, no attacks are made."/>
    <rule id="sr-batfoc"      name="Battle Focus"          description="This unit may choose to Run in the Movement Phase and still shoot in the following Shooting Phase. If it does, all shooting is resolved at Ballistic Skill 2."/>

    <!-- Psychic -->
    <rule id="sr-psym1"       name="Psychic Mastery (1)"   description="This model may cast up to 1 Psychic Power per phase."/>
    <rule id="sr-psym2"       name="Psychic Mastery (2)"   description="This model may cast up to 2 Psychic Powers per phase."/>
    <rule id="sr-psym3"       name="Psychic Mastery (3)"   description="This model may cast up to 3 Psychic Powers per phase."/>
    <rule id="sr-rnwarding"   name="Runes of Warding"      description="Any enemy model within 18&quot; and line of sight must reduce its Leadership by -3 when making Psychic Checks. Not cumulative with other Runes of Warding models."/>
    <rule id="sr-rnwitnessing" name="Runes of Witnessing"  description="Once per Game Turn, this model may re-roll any number of dice when making a Psychic Check."/>
    <rule id="sr-pfarseer"    name="Path of the Farseer"   description="This model gains the Runes of Fate Psychic Discipline and the Divination, Telepathy, and Thaumaturgy Psychic Disciplines. See Liber Antiquia p.24 and core rulebook p.322."/>
    <rule id="sr-pdead"       name="Path of the Dead"      description="This model gains the Runes of Twilight Psychic Discipline and the Thaumaturgy Psychic Discipline. Allows selection of up to two Wraith Sub-type units per model with this rule in the Detachment."/>
    <rule id="sr-pshaper"     name="Path of the Shaper"    description="All Infantry models in a unit with this model gain Feel No Pain (5+). At the start of the Shooting Phase, the model may instead gain Battlesmith (3+) until the start of its next turn, losing the Feel No Pain benefit."/>
    <rule id="sr-runesofwar"  name="The Runes of War"      description="This model automatically knows the Thaumaturgy Discipline and all powers from the Runes of Battle Discipline. When not in a Seer Council, pick a single Runes of Battle power instead."/>
    <rule id="sr-commofminds" name="Communion of Minds"    description="Models with this rule in a unit cast as a group. Use majority Leadership. 1-3 models: Psychic Mastery (1). 4-6 models: Psychic Mastery (2). 7-10 models: Psychic Mastery (3)."/>
    <rule id="sr-agentpand"   name="Agent of Pandemonium"  description="This model gains the Phantasmancy, Thaumaturgy, and Telepathy Psychic Disciplines."/>

    <!-- Sub-type rules -->
    <rule id="sr-legfall"     name="Legacies of the Fall"  description="This model has Hatred (Daemons). Units with this rule suffer -1 Leadership whilst locked in combat with at least one model with the Daemon Unit Type."/>
    <rule id="sr-support"     name="Support Squad"         description="This unit may not be selected as a Compulsory Troops choice."/>
    <rule id="sr-bulky2"      name="Bulky (2)"             description="Each model with this rule takes up 2 spaces in a Transport rather than 1."/>
    <rule id="sr-bulky4"      name="Bulky (4)"             description="Each model with this rule takes up 4 spaces in a Transport rather than 1."/>
    <rule id="sr-bulky5"      name="Bulky (5)"             description="Each model with this rule takes up 5 spaces in a Transport rather than 1."/>
    <rule id="sr-bulky6"      name="Bulky (6)"             description="Each model with this rule takes up 6 spaces in a Transport rather than 1."/>
    <rule id="sr-wraithtypes" name="Wraith Sub-type"       description="Wraith models are subject to Wraithsight: at the start of each Movement Phase take a Leadership test using unmodified Leadership. Pass: no penalty, may react normally. Fail: -2 to Move, WS, BS, and I until next Movement Phase. Models within 12&quot; of a friendly model with Guide Stones automatically pass. Wraith models may fire all weapons in each Shooting Attack, fire Heavy/Ordnance counting as Stationary even if moved, declare Charges normally, ignore Night Fighting, ignore Initiative penalties in Difficult/Dangerous Terrain when charging, cannot be affected by Cybertheurgic Rites, and ignore Disruption and Haywire."/>
    <rule id="sr-wraithconc"  name="Wraith Conclave"       description="When deployed, all models with this rule must be placed in unit coherency, but afterwards operate independently. Each model counts as its own unit for Victory Points."/>
    <rule id="sr-wraithbcore" name="Wraithbone Core"       description="This model ignores all Psychic Powers, Cybertheurgic Rites, Haywire, and Disruption(X). Weapons with these rules must damage this model normally using Strength. When destroyed, Catastrophic Damage resolves at AP2."/>
    <rule id="sr-gravplat"    name="Grav-Platform Sub-type" description="If a unit with Grav-Platform models has no non-Grav-Platform models remaining, all Grav-Platform models are removed as casualties. Grav-Platform models cannot shoot as part of any Reaction but may fire Heavy/Ordnance counting as Stationary even if they moved."/>
    <rule id="sr-mechtype"    name="Mechanised Sub-type"   description="Poisoned/Fleshbane wounds must be re-rolled. Failed To Wound rolls for Armourbane weapons must be re-rolled. May attack with all weapons in Shooting, fire Heavy/Ordnance counting as Stationary, and declare Charges normally. Resolved as Dreadnought for attack purposes. No non-Mechanised models may join this unit."/>
    <rule id="sr-opentopped6" name="Open-Topped (6)"       description="Up to 6 models embarked may make a Shooting Attack in the Shooting Phase, measuring from the Transport hull. Models count as having moved. Cannot exceed Reaction limits. +1 to Vehicle Damage Table rolls against this model."/>

    <!-- Aspect Shrine rules -->
    <rule id="sr-aspfire"     name="Aspect Shrine (Fire Dragon)"     description="This model belongs to the Fire Dragon Aspect Shrine. See Liber Antiquia p.14 for full Aspect Shrine rules and army building limitations."/>
    <rule id="sr-aspscorp"    name="Aspect Shrine (Striking Scorpion)" description="This model belongs to the Striking Scorpion Aspect Shrine. See Liber Antiquia p.17 for full rules."/>
    <rule id="sr-aspbanshee"  name="Aspect Shrine (Howling Banshee)" description="This model belongs to the Howling Banshee Aspect Shrine. See Liber Antiquia p.15 for full rules."/>
    <rule id="sr-aspdire"     name="Aspect Shrine (Dire Avenger)"    description="This model belongs to the Dire Avenger Aspect Shrine. See Liber Antiquia p.15 for full rules."/>
    <rule id="sr-aspdarkreap" name="Aspect Shrine (Dark Reaper)"     description="This model belongs to the Dark Reaper Aspect Shrine. See Liber Antiquia p.14 for full rules."/>
    <rule id="sr-aspspectre"  name="Aspect Shrine (Shadow Spectre)"  description="This model belongs to the Shadow Spectre Aspect Shrine. See Liber Antiquia p.14 for full rules."/>
    <rule id="sr-aspspear"    name="Aspect Shrine (Shining Spear)"   description="This model belongs to the Shining Spear Aspect Shrine. See Liber Antiquia p.16 for full rules."/>
    <rule id="sr-aspswoophawk" name="Aspect Shrine (Swooping Hawk)"  description="This model belongs to the Swooping Hawk Aspect Shrine. See Liber Antiquia p.16 for full rules."/>
    <rule id="sr-aspwarpspid" name="Aspect Shrine (Warp Spider)"     description="This model belongs to the Warp Spider Aspect Shrine. See Liber Antiquia p.17 for full rules."/>
    <rule id="sr-aspascend"   name="Aspect Ascendant"                description="Before the first turn, all models in this unit must be assigned to another unit in the same Detachment with the corresponding Aspect Shrine (X) rule. No more than one Exarch per unit. Once assigned, the Exarch is part of that unit permanently. No Victory Points are scored for removing an Exarch as a casualty."/>
    <rule id="sr-flextact"    name="Flexible Tactics"                description="At the beginning of the Controlling Player's turn, choose one tactic: Defensive Posture (if half or more models within 6&quot; of an Objective, gain Feel No Pain (5+), Battle-Hardened (1), and Stubborn) or Offensive Rush (each weapon makes one additional shot)."/>
    <rule id="sr-shadowdeath" name="Shadow of Death"                 description="An enemy unit with at least one model within 12&quot; of this model must roll an additional D6 when making any Leadership Check, discarding the lowest die. Models with Fearless are unaffected."/>

    <!-- Special unit rules -->
    <rule id="sr-guardarti"   name="Guardian Artillerists"  description="The battery must have one Guardian Crew per Support Weapon to fire all weapons. Fewer Crew than Weapons means only Crew-count weapons may fire. While Crew count equals or exceeds Weapon count, the unit cannot be Pinned."/>
    <rule id="sr-guardoffs"   name="Guardian Officers"      description="Selected as a normal unit, but before the first turn all models must be assigned to units of Guardian Defenders, Storm Guardians, or Vaul's Wrath Support Batteries (Skyrunners to Windriders). Max one Officer per unit. Once assigned, permanent. No VP for removing Officers. Officer gains assigned unit's rules and sub-types but not their wargear options. If 3+ models, does not use a Force Organisation slot."/>
    <rule id="sr-bonecomp"    name="Bonesinger Companions"  description="Selected as a normal unit but before the first turn all Bonesingers must be assigned to units of Guardian Defenders, Storm Guardians, or Vaul's Wrath Support Batteries. Max one Bonesinger per unit. Once assigned, permanent. No VP for removing Bonesingers. Bonesinger gains assigned unit's rules and sub-types."/>
    <rule id="sr-seercouncilret" name="Seer Council Retinue" description="A Seer Council may be selected as a Retinue Squad for a model with Path of the Farseer instead of as an Elites choice. Does not use a Force Organisation slot. Must be deployed with its Leader who may not voluntarily leave. All models gain Chosen Warriors. Jetbike status must match Leader's."/>
    <rule id="sr-guardgate"   name="Guardian of the Gates"  description="This model may only be selected in an army that also includes a Webway Gate Fortification. It must be assigned to Reserves and deployed via the Webway Strike special rule."/>
    <rule id="sr-webwaystrike" name="Webway Strike"         description="Before Game Turn 1, assign Reserve units to Webway Strike. From Turn 2, deploy one assigned unit per turn without a Reserve roll through the Webway Gate arch line. Enemy units within 6&quot; must take a Pinning test. Non-Pinned/Falling Back enemy units in range and LoS may make an Interceptor Reaction. Deployed units may not Move or Run that turn but may Shoot and Assault."/>
    <rule id="sr-myststat"    name="Mysterious Statuary"    description="After Deployment Zones are set but before deployment, place the two Wraithbone Arches 5&quot; apart, at least 6&quot; from the opposing Deployment Zone and not in Difficult/Dangerous/Impassable terrain. Asuryani units within 3&quot; gain Stubborn. Models in cover behind a Wraithbone Arch gain a 5+ Cover Save."/>
    <rule id="sr-holoemit"    name="Holo-Emitter"           description="This Barricade provides a 5+ Cover Save. Wounds from Blast attacks targeting models claiming Cover from this model must be re-rolled."/>
    <rule id="sr-shootwrath1" name="Hammer of Wrath (1)"    description="Each model makes 1 additional automatic hit at unmodified Strength with no AP when making a successful Charge."/>
    <rule id="sr-warlordkh"   name="Warlord: Hand of Asuryan" description="All models with any Aspect Shrine (X) rule in the same army gain Stubborn. Models with Aspect Shrine (Dire Avenger) may use Asurmen's Leadership. Once per turn, the army may make an additional Reaction in any one Phase (does not need to be declared in advance)."/>
    <rule id="sr-warlordwind" name="Warlord: Cry of the Wind" description="Models with Aspect Shrine (Swooping Hawk) in the same army gain Hit and Run and Reaping Blow (1). The army gains an additional Reaction in the opposing player's Movement Phase as long as Baharroth is alive."/>
    <rule id="sr-warlordlance" name="Warlord: The Lancer's Charge" description="Once per game in the Charge phase, declare a Lance Charge: all models with Aspect Shrine (Shining Spear) roll an extra dice and discard the lowest for Charge Distance, and their Hammer of Wrath (X) increases by 1 this turn. The army gains an additional Reaction in the Movement Phase as long as Drastanta is alive."/>
    <rule id="sr-warlordrhana" name="Warlord: Rhana Dandra" description="All models with Aspect Shrine (Fire Dragon) in the same army gain Dragon of Myth and Feel No Pain (5+). The army gains an additional Reaction in the Shooting Phase as long as Fuegan is alive."/>
    <rule id="sr-warlordreaper" name="Warlord: Reaper of Souls" description="All models with Aspect Shrine (Shadow Spectre) in the same army gain Night Vision and Ignores Cover. The army gains an additional Reaction in the opposing player's Shooting Phase as long as Irillyth is alive."/>
    <rule id="sr-warlordduell" name="Warlord: The Duellist's Fury" description="On a turn a unit with Aspect Shrine (Striking Scorpion) charges or is charged, they gain Riposte (1) and improve their Counter-Attack (X) and Rage (X) by 1. The army gains an additional Reaction in the Assault Phase as long as Karandras is alive."/>
    <rule id="sr-warlordgaze" name="Warlord: The Reaper's Gaze" description="After Deployment, nominate a single enemy unit. All models with Aspect Shrine (Dark Reaper) gain Precision Shots (5+) and Precision Strikes (5+) against the nominated unit. The army gains an additional Reaction in the Shooting Phase as long as Maugan Ra is alive."/>
    <rule id="sr-warlordstorm" name="Warlord: Storm of Silence" description="All models with Aspect Shrine (Howling Banshee) gain Furious Charge (1) and Crusader. The army gains an additional Reaction in the Assault Phase as long as Jain Zar is alive."/>
    <rule id="sr-warlordblood" name="Warlord: Fate Reader"  description="Before deployment, up to three Infantry or Cavalry units may be given Infiltrate and Scout. The army may make an additional Reaction in any one Phase of the Controlling Player's choice once per turn as long as Eldrad is alive."/>
    <rule id="sr-dragofmyth"  name="Dragon of Myth"         description="At the start of any Fight Sub-phase, each model with this rule in base contact with an enemy model makes D3 additional attacks at Initiative step 10 at Strength 4, AP-, counted as Flame attacks."/>
    <rule id="sr-unqresolve"  name="Unquenchable Resolve"   description="At the end of any phase in which this model suffers one or more unsaved Wounds, its Strength and Attacks increase by +1 for each unsaved Wound suffered. These bonuses are permanent for the rest of the game."/>
    <rule id="sr-dawntwilight" name="Dawn of Twilight"      description="During missions where Night Fighting is in effect, the controlling player may force Night Fighting without a dice roll. The Controlling Player may re-roll any dice to determine if Night Fighting stays in effect."/>
    <rule id="sr-shieldgrace" name="Shield of Grace"        description="Whenever Asurmen fights in a Challenge, his Invulnerable Save is increased to 3+."/>
    <rule id="sr-terrorslen"  name="Terror's Lament"        description="During the Assault phase, the Reactive Player may not make Reactions targeting a unit containing a model with Terror's Lament. Enemy models in base contact have their Attacks and Initiative reduced by 1 (minimum 1). Does not activate if the unit makes a Disordered Charge."/>
    <rule id="sr-abloodyhand" name="A Bloody-Handed God"    description="The Avatar of Khaine may never be selected as your Warlord and may not select a Warlord Trait. It may never join or be joined by any other model or unit. When it loses its last Wound, before removal all models within D6+6&quot; suffer an automatic Hit at Str 8, AP-."/>
    <rule id="sr-khaineawk"   name="Khaine Awakened"        description="All friendly units within 12&quot; of the Avatar with the Asuryani Sub-type gain Stubborn and Rage (2)."/>
    <rule id="sr-crownsky"    name="The Crown of the Seventh Sky" description="Drastanta and a unit they have joined may make a single Reaction in the Movement Phase without expending a Reaction Allotment point."/>
    <rule id="sr-whirlwind"   name="Whirlwind of Death"     description="Maugan Ra may fire The Maugetar twice during the Controlling Player's Shooting Phase. These attacks may target different units."/>
    <rule id="sr-soulshatter"  name="Soul-Shatter"          description="Successful Invulnerable Saves made against Wounds from a weapon with this rule must be re-rolled."/>
    <rule id="sr-ghoststrike" name="Ghoststrike"            description="On any turn in which Irillyth charges a unit that has suffered at least one hit from a Ghostlight weapon, the Spear of Starlight's Wanelight Glaive profile changes to Strength +3 and gains Armourbane (Melee) and Murderous Strike (5+) until the end of that player turn."/>
    <rule id="sr-transportskiff" name="Transport Skiff"     description="This model gains the Infantry Transport and Assault Vehicle Special Rules and counts as a Vehicle for Transport purposes. When it loses its last Wound, all embarked models suffer a S6, AP- hit allocated by the Controlling Player. Survivors are placed where the model was in unit coherency at least 1&quot; from enemies. Models that cannot be placed are removed. The unit takes a Pinning Test."/>
    <rule id="sr-precthrow"   name="Precise Throw"          description="After completing a Deep Strike Assault, one model in this unit may make a Shooting Attack with this weapon. This counts as a Shooting Attack in the Movement Phase. The unit may still shoot in the Shooting Phase but must target the same unit; if no valid targets remain it cannot shoot another target."/>
    <rule id="sr-strrafrun"   name="Strafing Run"           description="When this model makes a Shooting Attack targeting a unit that is not a Flyer, it does not need to observe the normal Flyer targeting restrictions."/>
  </sharedRules>

