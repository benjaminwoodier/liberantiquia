  <selectionEntries>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- FARSEER — 150 pts                                         -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="la-unit-farseer" name="Farseer" type="unit" hidden="false"
      page="30" publicationId="a368-64f0-10c7-la01">

      <categoryLinks>
        <!-- Primary slot -->
        <categoryLink id="la-farseer-cat-hq"       targetId="la-cat-hq"        name="HQ"        primary="true"/>
        <!-- Sub-type tags -->
        <categoryLink id="la-farseer-cat-asuryani"  targetId="la-cat-asuryani"  name="Asuryani"  primary="false"/>
        <categoryLink id="la-farseer-cat-infantry"  targetId="la-cat-infantry"  name="Infantry"  primary="false"/>
        <categoryLink id="la-farseer-cat-character" targetId="la-cat-character" name="Character" primary="false"/>
        <categoryLink id="la-farseer-cat-psyker"    targetId="la-cat-psyker"    name="Psyker"    primary="false"/>
      </categoryLinks>

      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="150"/>
      </costs>

      <!-- Unit-level stat profile (displayed above model entry per BSData convention) -->
      <profiles>
        <profile id="la-farseer-statblock" name="Farseer" typeId="la-pt-unit">
          <characteristics>
            <characteristic typeId="la-ct-m"  name="Move">7</characteristic>
            <characteristic typeId="la-ct-ws" name="WS">5</characteristic>
            <characteristic typeId="la-ct-bs" name="BS">5</characteristic>
            <characteristic typeId="la-ct-s"  name="S">3</characteristic>
            <characteristic typeId="la-ct-t"  name="T">3</characteristic>
            <characteristic typeId="la-ct-w"  name="W">3</characteristic>
            <characteristic typeId="la-ct-i"  name="I">5</characteristic>
            <characteristic typeId="la-ct-a"  name="A">2</characteristic>
            <characteristic typeId="la-ct-ld" name="Ld">10</characteristic>
            <characteristic typeId="la-ct-sv" name="Save">-</characteristic>
            <characteristic typeId="la-ct-ut" name="Unit Type">Infantry (Asuryani, Character, Psyker)</characteristic>
          </characteristics>
        </profile>
      </profiles>

      <!-- Special rules on the unit -->
      <rules>
        <rule id="la-farseer-note" name="Farseer Special Rules"
          description="See also the Shared Rules section for: Independent Character, Fleet (1), Adamantium Will (3+), Psychic Mastery (2), Path of the Farseer, Runes of Warding, Runes of Witnessing, Legacies of the Fall, Battle Focus."/>
      </rules>

      <selectionEntries>

        <!-- Single Farseer model -->
        <selectionEntry id="la-farseer-model" name="Farseer" type="model" hidden="false">
          <constraints>
            <constraint id="la-farseer-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
            <constraint id="la-farseer-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
          </constraints>
          <costs>
            <cost name="Pts" typeId="la-cost-pts" value="0"/>
          </costs>

          <!-- Mandatory wargear (min=1 max=1 means always included) -->
          <entryLinks>
            <entryLink id="la-farseer-gear-runearmour" name="Rune Armour"
              type="selectionEntry" targetId="la-gear-runearmour" hidden="false">
              <constraints>
                <constraint id="la-farseer-runearmour-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="la-farseer-runearmour-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
            <entryLink id="la-farseer-gear-shurikenpistol" name="Shuriken Pistol"
              type="selectionEntry" targetId="la-gear-shurikenpistol" hidden="false">
              <constraints>
                <constraint id="la-farseer-shurikenpistol-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="la-farseer-shurikenpistol-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
            <entryLink id="la-farseer-gear-plasmagrenades" name="Plasma Grenades"
              type="selectionEntry" targetId="la-gear-plasmagrenades" hidden="false">
              <constraints>
                <constraint id="la-farseer-plasmagrenades-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="la-farseer-plasmagrenades-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
          </entryLinks>

          <!-- Mandatory special rules -->
          <ruleLinks>
            <ruleLink id="la-farseer-rl-ic"         targetId="la-sr-ic"          name="Independent Character"/>
            <ruleLink id="la-farseer-rl-fleet1"      targetId="la-sr-fleet1"      name="Fleet (1)"/>
            <ruleLink id="la-farseer-rl-aw3"         targetId="la-sr-aw3"         name="Adamantium Will (3+)"/>
            <ruleLink id="la-farseer-rl-psym2"       targetId="la-sr-psym2"       name="Psychic Mastery (2)"/>
            <ruleLink id="la-farseer-rl-pfarseer"    targetId="la-sr-pfarseer"    name="Path of the Farseer"/>
            <ruleLink id="la-farseer-rl-rnwarding"   targetId="la-sr-rnwarding"   name="Runes of Warding"/>
            <ruleLink id="la-farseer-rl-rnwitnessing" targetId="la-sr-rnwitnessing" name="Runes of Witnessing"/>
            <ruleLink id="la-farseer-rl-legfall"     targetId="la-sr-legfall"     name="Legacies of the Fall"/>
            <ruleLink id="la-farseer-rl-batfoc"      targetId="la-sr-batfoc"      name="Battle Focus"/>
          </ruleLinks>

          <!-- Optional: replace Witch Weapon with Singing Spear -->
          <selectionEntryGroups>
            <selectionEntryGroup id="la-farseer-wpngroup" name="Primary Weapon" defaultSelectionEntryId="la-farseer-wpn-witch">
              <entryLinks>
                <entryLink id="la-farseer-wpn-witch" name="Witch Weapon"
                  type="selectionEntry" targetId="la-gear-witchwpn" hidden="false">
                  <costs>
                    <cost name="Pts" typeId="la-cost-pts" value="0"/>
                  </costs>
                </entryLink>
                <entryLink id="la-farseer-wpn-singingspear" name="Singing Spear (+5 pts)"
                  type="selectionEntry" targetId="la-gear-singingspear" hidden="false">
                  <costs>
                    <cost name="Pts" typeId="la-cost-pts" value="5"/>
                  </costs>
                </entryLink>
              </entryLinks>
            </selectionEntryGroup>
          </selectionEntryGroups>

        </selectionEntry><!-- /Farseer model -->

      </selectionEntries>

      <!-- Optional upgrades at unit level -->
      <selectionEntryGroups>
        <selectionEntryGroup id="la-farseer-optgroup" name="Optional Upgrades">
          <entryLinks>
            <entryLink id="la-farseer-opt-augury" name="Augury Scanner"
              type="selectionEntry" targetId="la-gear-auguryscanner" hidden="false">
              <constraints>
                <constraint id="la-farseer-opt-augury-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
            <entryLink id="la-farseer-opt-commbead" name="Comm-Bead"
              type="selectionEntry" targetId="la-gear-commbeard" hidden="false">
              <constraints>
                <constraint id="la-farseer-opt-commbead-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
          </entryLinks>
        </selectionEntryGroup>
      </selectionEntryGroups>

    </selectionEntry><!-- /Farseer unit -->


    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- GUARDIAN DEFENDERS — 85 pts base (10 models)             -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="la-unit-guarddef" name="Guardian Defenders" type="unit" hidden="false"
      page="48" publicationId="a368-64f0-10c7-la01">

      <categoryLinks>
        <categoryLink id="la-gd-cat-troops"    targetId="la-cat-troops"    name="Troops"    primary="true"/>
        <categoryLink id="la-gd-cat-asuryani"  targetId="la-cat-asuryani"  name="Asuryani"  primary="false"/>
        <categoryLink id="la-gd-cat-infantry"  targetId="la-cat-infantry"  name="Infantry"  primary="false"/>
        <categoryLink id="la-gd-cat-line"      targetId="la-cat-line"      name="Line"      primary="false"/>
      </categoryLinks>

      <costs>
        <cost name="Pts" typeId="la-cost-pts" value="85"/>
      </costs>

      <!-- Unit-level stat profile for Guardian Defender -->
      <profiles>
        <profile id="la-gd-statblock" name="Guardian Defender" typeId="la-pt-unit">
          <characteristics>
            <characteristic typeId="la-ct-m"  name="Move">7</characteristic>
            <characteristic typeId="la-ct-ws" name="WS">4</characteristic>
            <characteristic typeId="la-ct-bs" name="BS">4</characteristic>
            <characteristic typeId="la-ct-s"  name="S">3</characteristic>
            <characteristic typeId="la-ct-t"  name="T">3</characteristic>
            <characteristic typeId="la-ct-w"  name="W">1</characteristic>
            <characteristic typeId="la-ct-i"  name="I">5</characteristic>
            <characteristic typeId="la-ct-a"  name="A">1</characteristic>
            <characteristic typeId="la-ct-ld" name="Ld">7</characteristic>
            <characteristic typeId="la-ct-sv" name="Save">5+</characteristic>
            <characteristic typeId="la-ct-ut" name="Unit Type">Infantry (Asuryani, Line)</characteristic>
          </characteristics>
        </profile>
        <profile id="la-gd-defplat-statblock" name="Defender Platform" typeId="la-pt-unit">
          <characteristics>
            <characteristic typeId="la-ct-m"  name="Move">7</characteristic>
            <characteristic typeId="la-ct-ws" name="WS">1</characteristic>
            <characteristic typeId="la-ct-bs" name="BS">4</characteristic>
            <characteristic typeId="la-ct-s"  name="S">1</characteristic>
            <characteristic typeId="la-ct-t"  name="T">5</characteristic>
            <characteristic typeId="la-ct-w"  name="W">2</characteristic>
            <characteristic typeId="la-ct-i"  name="I">1</characteristic>
            <characteristic typeId="la-ct-a"  name="A">1</characteristic>
            <characteristic typeId="la-ct-ld" name="Ld">-</characteristic>
            <characteristic typeId="la-ct-sv" name="Save">3+</characteristic>
            <characteristic typeId="la-ct-ut" name="Unit Type">Infantry (Asuryani, Grav-Platform)</characteristic>
          </characteristics>
        </profile>
      </profiles>

      <selectionEntries>

        <!-- ── 10 mandatory Guardian Defender models ─────────────── -->
        <selectionEntry id="la-gd-model" name="Guardian Defender" type="model" hidden="false">
          <constraints>
            <constraint id="la-gd-model-min" type="min" value="10" field="selections" scope="parent" shared="true"/>
            <constraint id="la-gd-model-max" type="max" value="20" field="selections" scope="parent" shared="true"/>
          </constraints>
          <costs>
            <!-- First 10 are included in unit base cost; additional 10 at +8 pts each -->
            <cost name="Pts" typeId="la-cost-pts" value="8"/>
          </costs>

          <entryLinks>
            <!-- Each Guardian Defender has: Mesh Armour, Shuriken Catapult, Plasma Grenades -->
            <entryLink id="la-gd-gear-mesh" name="Mesh Armour"
              type="selectionEntry" targetId="la-gear-mesharmour" hidden="false">
              <constraints>
                <constraint id="la-gd-mesh-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="la-gd-mesh-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
            <entryLink id="la-gd-gear-shurikencat" name="Shuriken Catapult"
              type="selectionEntry" targetId="la-gear-shurikencat" hidden="false">
              <constraints>
                <constraint id="la-gd-shurikencat-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="la-gd-shurikencat-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
            <entryLink id="la-gd-gear-plasmagrenades" name="Plasma Grenades"
              type="selectionEntry" targetId="la-gear-plasmagrenades" hidden="false">
              <constraints>
                <constraint id="la-gd-plasmagrenades-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="la-gd-plasmagrenades-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
            </entryLink>
          </entryLinks>

          <ruleLinks>
            <ruleLink id="la-gd-rl-fleet1"  targetId="la-sr-fleet1"  name="Fleet (1)"/>
            <ruleLink id="la-gd-rl-legfall" targetId="la-sr-legfall" name="Legacies of the Fall"/>
            <ruleLink id="la-gd-rl-batfoc"  targetId="la-sr-batfoc"  name="Battle Focus"/>
          </ruleLinks>
        </selectionEntry><!-- /Guardian Defender model -->

        <!-- ── Optional Defender Platform (1 per 10 Guardians) ──── -->
        <selectionEntry id="la-gd-defplat" name="Defender Platform" type="model" hidden="false">
          <constraints>
            <!-- 0 to 2 platforms allowed (1 per 10 guardians, max unit is 20 so max 2 platforms) -->
            <constraint id="la-gd-defplat-min" type="min" value="0" field="selections" scope="parent" shared="true"/>
            <constraint id="la-gd-defplat-max" type="max" value="2" field="selections" scope="parent" shared="true"/>
          </constraints>
          <costs>
            <cost name="Pts" typeId="la-cost-pts" value="20"/>
          </costs>

          <rules>
            <rule id="la-gd-defplat-rule-bulky" name="Bulky (2)"
              description="Each Defender Platform takes up 2 spaces in a Transport rather than 1."/>
            <rule id="la-gd-defplat-rule-grav" name="Grav-Platform"
              description="If a unit that includes Grav-Platform models has no non-Grav-Platform models remaining, all Grav-Platform models are removed as casualties. Grav-Platform models cannot shoot as part of any Reaction but may fire Heavy/Ordnance weapons counting as Stationary even if they moved."/>
          </rules>

          <!-- Platform default weapon: Shuriken Cannon; can swap -->
          <selectionEntryGroups>
            <selectionEntryGroup id="la-gd-defplat-wpngrp" name="Platform Weapon"
              defaultSelectionEntryId="la-gd-defplat-wpn-shurikencan">
              <entryLinks>
                <entryLink id="la-gd-defplat-wpn-shurikencan" name="Shuriken Cannon (included)"
                  type="selectionEntry" targetId="la-gear-shurikencan" hidden="false">
                  <costs>
                    <cost name="Pts" typeId="la-cost-pts" value="0"/>
                  </costs>
                </entryLink>
                <entryLink id="la-gd-defplat-wpn-scatlaser" name="Scatter Laser (+5 pts)"
                  type="selectionEntry" targetId="la-gear-defplat-scat" hidden="false">
                </entryLink>
                <entryLink id="la-gd-defplat-wpn-starcannon" name="Starcannon (+10 pts)"
                  type="selectionEntry" targetId="la-gear-defplat-starcannon" hidden="false">
                </entryLink>
                <entryLink id="la-gd-defplat-wpn-aml" name="Aeldari Missile Launcher (+10 pts)"
                  type="selectionEntry" targetId="la-gear-defplat-aml" hidden="false">
                </entryLink>
                <entryLink id="la-gd-defplat-wpn-brightlance" name="Bright Lance (+15 pts)"
                  type="selectionEntry" targetId="la-gear-defplat-brightlance" hidden="false">
                </entryLink>
              </entryLinks>
            </selectionEntryGroup>
          </selectionEntryGroups>

        </selectionEntry><!-- /Defender Platform -->

      </selectionEntries>

      <!-- Unit-level optional upgrades (one model each) -->
      <selectionEntryGroups>

        <selectionEntryGroup id="la-gd-opt-standard" name="Craftworld Standard (0-1)">
          <constraints>
            <constraint id="la-gd-opt-standard-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
          </constraints>
          <entryLinks>
            <entryLink id="la-gd-opt-standard-link" name="Craftworld Standard"
              type="selectionEntry" targetId="la-gear-craftstandard" hidden="false"/>
          </entryLinks>
        </selectionEntryGroup>

        <selectionEntryGroup id="la-gd-opt-augury" name="Augury Scanner (0-1)">
          <constraints>
            <constraint id="la-gd-opt-augury-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
          </constraints>
          <entryLinks>
            <entryLink id="la-gd-opt-augury-link" name="Augury Scanner"
              type="selectionEntry" targetId="la-gear-auguryscanner" hidden="false"/>
          </entryLinks>
        </selectionEntryGroup>

        <selectionEntryGroup id="la-gd-opt-commbead" name="Comm-Bead (0-1)">
          <constraints>
            <constraint id="la-gd-opt-commbead-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
          </constraints>
          <entryLinks>
            <entryLink id="la-gd-opt-commbead-link" name="Comm-Bead"
              type="selectionEntry" targetId="la-gear-commbeard" hidden="false"/>
          </entryLinks>
        </selectionEntryGroup>

      </selectionEntryGroups>

    </selectionEntry><!-- /Guardian Defenders unit -->

  </selectionEntries>

</catalogue>
