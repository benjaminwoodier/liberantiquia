            <selectionEntryGroup id="seg-autarch-opt2" name="Optional Weapon 2">
              <constraints>
                <constraint id="con-autarch-opt2-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
              <selectionEntries>
