            <characteristic typeId="ct-ld" name="Ld">9</characteristic>
            <characteristic typeId="ct-sv" name="Save">4+</characteristic>
            <characteristic typeId="ct-ut" name="Unit Type">Infantry (Asuryani, Character)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntries>
        <selectionEntry id="u-ae-model" name="Exarch" type="model" hidden="false">
          <constraints>
            <constraint id="con-ae-model-min" type="min" value="1"  field="selections" scope="parent" shared="true"/>
            <constraint id="con-ae-model-max" type="max" value="4"  field="selections" scope="parent" shared="true"/>
          </constraints>
          <costs><cost name="Pts" typeId="ct-pts" value="20"/></costs>
          <entryLinks>
