    <!-- ══ WORLD-RUNES (Rites of War) ══════════════════════════════════════════ -->

    <selectionEntry id="wr-serpenthost" name="World-Rune: The Serpent Host" type="upgrade" hidden="false">
      <constraints>
        <constraint id="con-wr-sh-no-fort" type="max" value="0" field="selections" scope="force" shared="true" includeChildForces="false" childId="cat-fort" comment="May not select any Fortification choices"/>
      </constraints>
      <modifiers>
        <modifier type="set" field="hidden" value="false"/>
      </modifiers>
      <rules>
        <rule id="ru-wr-serpenthost" name="World-Rune: The Serpent Host" description="EFFECTS: Windrider Squads do not have the Support Squad rule. Compulsory Troop Windrider Squads gain the Line Sub-type. Vyper Squadrons may be taken as non-Compulsory Troops. Shining Spears may be taken as Elites. One unit with Aspect Shrine (Shining Spear) may be selected without restriction regardless of other Aspect Shrine selections. LIMITATIONS: Must select more units with Skyrunner, Vyper, or Raptor Jetbikes than units without. Compulsory HQ choices must all have Skyrunner Jetbikes. Any unit without the Cavalry Unit Type not beginning Embarked, or Vehicle without Transport/Fast Sub-types, must begin in Reserve if the mission allows it. May not select any Fortification choices."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="wr-swordwind" name="World-Rune: The Sword-Wind" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-wr-swordwind" name="World-Rune: The Sword-Wind" description="EFFECTS: May include up to two Aspect Exarch units instead of one. An Autarch may select a second Aspect Shrine Upgrade (different to the first, paying its points cost). LIMITATIONS: Must include an Autarch who must be the Warlord unless a Phoenix Lord is present (in which case the Phoenix Lord must be the Warlord). May not be used as an Allied Detachment. May not include more non-Infantry units than Infantry units (Aspect Exarchs, Bonesinger Conclaves, Guardian Officer Cadres, Guardian Defenders, and Storm Guardians are not counted)."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="wr-echoesfallen" name="World-Rune: Echoes of the Fallen" type="upgrade" hidden="false">
      <constraints>
        <constraint id="con-wr-eof-wraith-guide" type="min" value="1" field="selections" scope="force" shared="true" includeChildForces="false" childId="u-wraithguide" comment="Must include a Wraith Guide"/>
        <constraint id="con-wr-eof-fa-max" type="max" value="1" field="selections" scope="force" shared="true" includeChildForces="false" childId="cat-fa" comment="Max 1 Fast Attack choice"/>
      </constraints>
      <rules>
        <rule id="ru-wr-echoesfallen" name="World-Rune: Echoes of the Fallen" description="EFFECTS: A single Wraith Guide, Wraithseer, or single-model Wraithlord Conclave may be taken as a Compulsory HQ choice, gaining Path of Command and the Character Sub-type. That model must be the Warlord. If not already equipped with Guide Stones, may select them at +15 pts. A Wraithseer selected this way does not count toward the 0-1 limit. Wraithblades and Wraithguard may be taken as Troops. Compulsory Troop Wraithblades and Wraithguard gain the Line Sub-type. Wraithblades and Wraithguard do not count toward the Wraith Guide's unit allowance. LIMITATIONS: Must include a Wraith Guide. Must include at least as many Wraith Sub-type units as units without (Guardian Officer Cadres, Guardian Defenders, and Storm Guardians are not counted). May not be used as an Allied Detachment. May only select a single Fast Attack choice. May never roll to Seize the Initiative. Counts as Distrusted Allies to all other Aeldari Sub-Factions."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="wr-huntersmoon" name="World-Rune: The Hunter's Moon" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-wr-huntersmoon" name="World-Rune: The Hunter's Moon" description="EFFECTS: Independent Characters may be given an Outcast Cloak at +10 pts each, and may also gain the Skirmish Sub-type and Scout for free. Any Character Sub-type model may be equipped with a Ranger Long-Rifle at +10 pts each. A single non-Character Infantry model per unit may be given a Gloom Field at +15 pts each. All Infantry models gain Move Through Cover. Shroud Runner units gain the Line Sub-type. Ranger units gain Pathfinder and lose Support Squad. LIMITATIONS: All Vehicle models must begin in Reserves. Cannot include more Heavy Support choices than Fast Attack choices. All Compulsory Troops must be Rangers."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="wr-tearslileath" name="World-Rune: The Tears of Lileath" type="upgrade" hidden="false">
      <constraints>
        <constraint id="con-wr-tol-seercouncil" type="min" value="1" field="selections" scope="force" shared="true" includeChildForces="false" childId="u-seercouncil" comment="Must include at least one Seer Council as an Elites choice"/>
      </constraints>
      <rules>
        <rule id="ru-wr-tearslileath" name="World-Rune: The Tears of Lileath" description="EFFECTS: A single Farseer gains Path of Command. May ignore the 0-1 limit on Seer Council units. All non-Vehicle models gain Adamantium Will (6+); Psyker Sub-type models gain Adamantium Will (3+) instead. Guardian Defenders, Storm Guardians, and Vaul's Wrath Support Batteries may add a single Warlock at +35 pts. Windrider Squads may add a single Warlock Skyrunner at +50 pts. May re-roll any dice to see which player takes the first turn or when attempting to Seize the Initiative. LIMITATIONS: The Warlord must be a Farseer or Eldrad Ulthran. May not be used as an Allied Detachment. Must include at least one Seer Council as an Elites choice. Cannot include more Psyker Sub-type units than units without. Any unit that suffers Perils of the Warp is immediately Pinned (overrides unit types that normally ignore Pinning, but cannot affect units without a Leadership Characteristic)."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="wr-shatteredchains" name="World-Rune: The Shattered Chains" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-wr-shatteredchains" name="World-Rune: The Shattered Chains" description="EFFECTS: Independent Characters may select a Guardian Officer Cadre as part of the same Force Organisation Slot (min 2 models). This Retinue Squad does not use a FOC slot, is part of the IC's unit, must deploy with the IC, and the IC may not voluntarily leave. All Retinue Squad models lose Guardian Officers and Character Sub-type and gain Chosen Warriors. If the IC has a Skyrunner Jetbike, the Retinue must too. May ignore the 0-1 limit on Guardian Officer Cadres and take them as HQ choices (losing Guardian Officers and Character, gaining Chosen Warriors). Guardian Defenders may be Elites (BS 5 for all Guardian Defenders and Platforms in that unit). Storm Guardians may be Elites (WS 5 for all Storm Guardians and Platforms in that unit). All models without Aspect Shrine (X) or the Wraith Sub-type gain Stubborn (or ignore Crew Shaken if Vehicle). LIMITATIONS: Counts as Distrusted Allies to all other Eldar Sub-Factions. All Compulsory Troops must be Guardian Defenders or Storm Guardians and must take the maximum number of models possible."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="wr-crucibleblood" name="World-Rune: The Crucible of Blood" type="upgrade" hidden="false">
      <constraints>
        <constraint id="con-wr-cob-bonesinger" type="min" value="1" field="selections" scope="force" shared="true" includeChildForces="false" childId="u-bonesinger" comment="Must include at least one Bonesinger Conclave"/>
      </constraints>
      <rules>
        <rule id="ru-wr-crucibleblood" name="World-Rune: The Crucible of Blood" description="EFFECTS: All units eligible to take a Wave Serpent as Dedicated Transport may instead take a single Falcon if the unit numbers 5 models or fewer. Falcon Squadrons may be selected as Non-Compulsory Troops. Firestorm Squadrons and Night Spinner Squadrons may be selected as Elites. Bonesinger Companions models may ignore joining restrictions and may join any Infantry unit with the Asuryani Sub-type. May ignore the 0-1 limit on Bonesinger Conclaves and take them as Non-Compulsory Troops. If the Warlord does not have the Unique Sub-type, they gain Path of the Shaper. LIMITATIONS: All Infantry units must begin the battle Embarked upon a Transport; any Infantry not Embarked at the beginning of the first Game Turn are removed as casualties. Must include at least one Bonesinger Conclave. May not be used as an Allied Detachment. May not select any units with the Wraith Sub-type."/>
      </rules>
    </selectionEntry>

  

  <!-- ══ PSYCHIC DISCIPLINES ═══════════════════════════════════════════════════ -->
  <!-- Implemented as upgrade selectionEntries containing rule profiles,         -->
  <!-- one entry per discipline, each power listed as a rule or weapon profile   -->

    <selectionEntry id="psy-runesofbattle" name="Psychic Discipline: Runes of Battle" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-psy-rob-intro" name="Runes of Battle" description="A Psyker with this Discipline gains a single power from the list below (or more if a Special Rule permits), plus Aetheric Lightning. Each power has two sub-powers; choose which to use each time it is cast. See Liber Antiquia p.22-23 for full casting rules."/>
        <rule id="ru-psy-concealtreveal" name="Conceal / Reveal" description="CONCEAL: Instead of shooting, select a friendly unit within 18&quot;. It gains Shrouded (6+) until the start of your next turn. You may take a Psychic Check; if passed, it gains Shrouded (5+) instead. If failed, no benefit and suffer Perils of the Warp. REVEAL: Instead of shooting, select an enemy unit within 18&quot; and LoS, then take a Psychic Check. If passed, that unit may not benefit from Shrouded (X) and all Cover Saves from terrain are reduced by 1 (a 6+ becomes no save) until the start of your next turn. If failed, suffer Perils of the Warp."/>
        <rule id="ru-psy-emboldenhorify" name="Embolden / Horrify" description="EMBOLDEN: Instead of shooting, select a friendly unit within 18&quot;. It gains Stubborn until the start of your next turn. You may take a Psychic Check; if passed, it gains Fearless instead. If failed, no benefit and suffer Perils of the Warp. HORRIFY: Instead of shooting, select an enemy unit within 18&quot; and LoS, then take a Psychic Check. If passed, all models in the target unit reduce their Leadership by -2 until the start of your next turn. If failed, suffer Perils of the Warp."/>
        <rule id="ru-psy-quickenrestrain" name="Quicken / Restrain" description="QUICKEN: At the start of the Movement Phase, select a friendly Infantry unit within 18&quot;. It increases its Move by +2 for the current player turn. You may take a Psychic Check; if passed, it also gains Move Through Cover until the start of your next turn. If failed, no benefit and suffer Perils of the Warp. RESTRAIN: Instead of shooting, select an enemy Infantry unit within 18&quot; and LoS, then take a Psychic Check. If passed, all models reduce their Movement by -2 (minimum 1) and cannot Run until the start of your next turn. If failed, suffer Perils of the Warp."/>
        <rule id="ru-psy-empowerenervate" name="Empower / Enervate" description="EMPOWER: Instead of shooting, select a friendly unit within 18&quot;. It increases its Strength by +1 for the current player turn. You may take a Psychic Check; if passed, both Strength and Toughness increase by +1 for the current player turn. If failed, no benefit and suffer Perils of the Warp. ENERVATE: Instead of shooting, select an enemy unit within 18&quot; and LoS, then take a Psychic Check. If passed, all models in the target unit reduce their Strength by -1 (minimum 1) until the start of your next turn. If failed, suffer Perils of the Warp."/>
        <rule id="ru-psy-renewerdestruct" name="Renewer / Destructor" description="RENEWER: Instead of shooting, select a friendly unit with at least one model within 18&quot;. One model of your choice regains a single lost Wound. You may take a Psychic Check; if passed, up to three lost Wounds are regained across the target unit. If failed, no benefit and suffer Perils of the Warp. Cannot increase a model's Wounds beyond its starting Wounds Characteristic. DESTRUCTOR: Psychic Weapon — Template, Str 5, AP 5, Assault 1, Fleshbane, Torrent (9&quot;), Breaching (6+), Psychic Focus."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="psy-runesoffate" name="Psychic Discipline: Runes of Fate" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-psy-rof-intro" name="Runes of Fate" description="A Psyker with this Discipline gains ALL powers in this Discipline, plus Aetheric Lightning. See Liber Antiquia p.24."/>
        <rule id="ru-psy-fortune" name="Fortune" description="Once per turn, at the start of any Phase, select a friendly Aeldari Faction unit within 18&quot; and take a Psychic Check. If passed, the target unit may re-roll all failed Armour Saves or Invulnerable Saves for the duration of that Phase, at a penalty of -1 to Save rolls (maximum 6+)."/>
        <rule id="ru-psy-guide" name="Guide" description="Instead of shooting, select a friendly unit within 18&quot; and take a Psychic Check. If passed, the target unit's ranged weapons gain the Twin-Linked rule for the duration of the current player turn."/>
        <rule id="ru-psy-eldritchstorm" name="Eldritch Storm" description="Psychic Weapon — 24&quot;, Str 3, AP 4, Assault 1, Large Blast (5&quot;), Fleshbane, Haywire, Pinning, Psychic Focus, Gathering Storm."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="psy-runesoftwilight" name="Psychic Discipline: Runes of Twilight" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-psy-rot-intro" name="Runes of Twilight" description="A Psyker with this Discipline gains ALL powers in this Discipline, plus Aetheric Lightning. See Liber Antiquia p.25."/>
        <rule id="ru-psy-voiceoftwilight" name="Voice of Twilight" description="Instead of shooting, select a friendly unit with a model within 18&quot; that contains at least one model with the Wraith Sub-type. Apply one of the following to all Wraith Sub-type models in the unit until the start of your next turn: Precision Shots (5+), Precision Strikes (5+), Split Fire, or Furious Charge. You may take a Psychic Check; if passed, apply two different options instead of one. If failed, no benefit and suffer Perils of the Warp."/>
        <rule id="ru-psy-executioner" name="Executioner (Runes of Twilight)" description="Psychic Weapon — 18&quot;, Str 4, AP -, Assault 4, Fleshbane, Deflagrate, Disruption (5+), Precision Shots (5+), Psychic Focus."/>
      </rules>
    </selectionEntry>

    <selectionEntry id="psy-phantasmancy" name="Psychic Discipline: Phantasmancy" type="upgrade" hidden="false">
      <rules>
        <rule id="ru-psy-phant-intro" name="Phantasmancy" description="A Psyker with this Discipline (Rillietann Sub-type only) gains ALL powers in this Discipline, plus Aetheric Lightning. See Liber Antiquia p.110."/>
        <rule id="ru-psy-veiloftears" name="Veil of Tears" description="At any point during the Controlling Player's Movement Phase, select a single enemy unit within 24&quot; and LoS. The target unit may not make Shooting Attacks against units composed entirely of the Rillietann Sub-type over 18&quot; until the start of your next turn. You may take a Psychic Check; if passed, the target unit may also not make Reactions against Rillietann units until the end of the Opposing Player's next turn. If failed, no effects are applied and suffer Perils of the Warp."/>
        <rule id="ru-psy-pealofbiscord" name="Peal of Discord" description="Psychic Weapon — 24&quot;, Str 4, AP -, Assault 4, Blind, Psychic Focus."/>
      </rules>
    </selectionEntry>

  </sharedSelectionEntries>

  <selectionEntries>

