              <constraints><constraint id="con-ae-armour-min" type="min" value="1" field="selections" scope="parent" shared="true"/><constraint id="con-ae-armour-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints>
            </entryLink>
            <entryLink id="el-ae-plasmagren" name="Plasma Grenades" type="selectionEntry" targetId="ge-plasmagrenades" hidden="false">
              <constraints><constraint id="con-ae-gren-min" type="min" value="1" field="selections" scope="parent" shared="true"/><constraint id="con-ae-gren-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints>
            </entryLink>
          </entryLinks>
          <ruleLinks>
            <ruleLink id="rl-ae-fleet1"    targetId="sr-fleet1"    name="Fleet (1)"/>
            <ruleLink id="rl-ae-aspascend" targetId="sr-aspascend" name="Aspect Ascendant"/>
            <ruleLink id="rl-ae-batfoc"    targetId="sr-batfoc"    name="Battle Focus"/>
            <ruleLink id="rl-ae-legfall"   targetId="sr-legfall"   name="Legacies of the Fall"/>
          </ruleLinks>
          <selectionEntryGroups>
            <selectionEntryGroup id="seg-ae-shrine" name="Aspect Shrine Upgrade">
              <constraints>
                <constraint id="con-ae-shrine-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
                <constraint id="con-ae-shrine-max" type="max" value="1" field="selections" scope="parent" shared="true"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="el-ae-shrine-darkreap"   name="Dark Reaper (+30 pts)"       type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="30"/></costs><ruleLinks><ruleLink id="rl-ae-aspdarkreap"  targetId="sr-aspdarkreap"  name="Aspect Shrine (Dark Reaper)"/><ruleLink id="rl-ae-relentless"    targetId="sr-relentless"   name="Relentless"/><ruleLink id="rl-ae-inescacc"      targetId="sr-inescacc"     name="Inescapable Accuracy"/><ruleLink id="rl-ae-fastshot"      targetId="sr-fastshot"     name="Fast Shot"/></ruleLinks><rules><rule id="ru-ae-darkreap" name="Dark Reaper Wargear" description="Gains Heavy Aspect Armour (replacing Aspect Armour), Reaper Launcher (Starswarm, Starshot, Starhawk). May replace Reaper Launcher with: Shuriken Cannon (free), Aeldari Missile Launcher (+10 pts), or Tempest Launcher (+20 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-direaveng"  name="Dire Avenger (+15 pts)"      type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><ruleLinks><ruleLink id="rl-ae-aspdire"        targetId="sr-aspdire"      name="Aspect Shrine (Dire Avenger)"/><ruleLink id="rl-ae-flextact"      targetId="sr-flextact"     name="Flexible Tactics"/><ruleLink id="rl-ae-fnp5"          targetId="sr-fnp5"         name="Feel No Pain (5+)"/></ruleLinks><rules><rule id="ru-ae-direaveng" name="Dire Avenger Wargear" description="Gains Shuriken Pistol, Augury Scanner, Twin-Linked Avenger Catapult. May replace Twin-Linked Avenger Catapult with Power Weapon (+10 pts) or Diresword (+25 pts). May replace Twin-Linked Avenger Catapult and Shuriken Pistol with Power Weapon and Improved Forceshield (+20 pts) or Diresword and Improved Forceshield (+35 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-firedragon" name="Fire Dragon (+15 pts)"       type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><ruleLinks><ruleLink id="rl-ae-aspfire"        targetId="sr-aspfire"      name="Aspect Shrine (Fire Dragon)"/><ruleLink id="rl-ae-wrecker"       targetId="sr-wrecker"      name="Wrecker"/><ruleLink id="rl-ae-crackshot"     targetId="sr-crackshot"    name="Crack Shot"/></ruleLinks><rules><rule id="ru-ae-firedragon" name="Fire Dragon Wargear" description="Gains Heavy Aspect Armour (replacing Aspect Armour), Melta Bombs, Fusion Gun. May replace Fusion Gun with: Khaine's Fury (free) or Firepike (+15 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-howlbansh"  name="Howling Banshee (+15 pts)"   type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><ruleLinks><ruleLink id="rl-ae-aspbanshee"     targetId="sr-aspbanshee"   name="Aspect Shrine (Howling Banshee)"/><ruleLink id="rl-ae-fleet2"        targetId="sr-fleet2"       name="Fleet (2)"/><ruleLink id="rl-ae-fear1"         targetId="sr-fear1"        name="Fear (1)"/><ruleLink id="rl-ae-acrobatic"     targetId="sr-acrobatic"    name="Acrobatic"/><ruleLink id="rl-ae-warshout"      targetId="sr-warshout"     name="War Shout"/></ruleLinks><rules><rule id="ru-ae-howlbansh" name="Howling Banshee Wargear" description="Gains Banshee Mask, Shuriken Pistol, Power Sword. May replace Power Sword with: Triskele (free), Executioner (+10 pts), or Two Mirrorswords (+20 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-shadspectre" name="Shadow Spectre (+25 pts)"   type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="25"/></costs><ruleLinks><ruleLink id="rl-ae-aspspectre"     targetId="sr-aspspectre"   name="Aspect Shrine (Shadow Spectre)"/><ruleLink id="rl-ae-fear1b"        targetId="sr-fear1"        name="Fear (1)"/><ruleLink id="rl-ae-shadowdeath"   targetId="sr-shadowdeath"  name="Shadow of Death"/><ruleLink id="rl-ae-relentless2"   targetId="sr-relentless"   name="Relentless"/><ruleLink id="rl-ae-shroud4"       targetId="sr-shroud4"      name="Shrouded (4+)"/></ruleLinks><rules><rule id="ru-ae-shadspectre" name="Shadow Spectre Wargear" description="Gains Heavy Aspect Armour (replacing Aspect Armour), Spectre Jet Pack, Haywire Grenades, Prism Rifle. May replace Prism Rifle with: Haywire Launcher (+5 pts) or Prism Blaster (+10 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-shinspear"  name="Shining Spear (+25 pts)"    type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="25"/></costs><ruleLinks><ruleLink id="rl-ae-aspspear"       targetId="sr-aspspear"     name="Aspect Shrine (Shining Spear)"/><ruleLink id="rl-ae-monsthunt"     targetId="sr-monsterhunt"  name="Monster Hunter"/><ruleLink id="rl-ae-pathfinder"     targetId="sr-pathfinder"   name="Pathfinder"/><ruleLink id="rl-ae-shroud4b"      targetId="sr-shroud4"      name="Shrouded (4+)"/><ruleLink id="rl-ae-relentless3"   targetId="sr-relentless"   name="Relentless"/><ruleLink id="rl-ae-firingp3"      targetId="sr-firingp3"     name="Firing Protocols (3)"/><ruleLink id="rl-ae-outflank"      targetId="sr-outflank"     name="Outflank"/></ruleLinks><rules><rule id="ru-ae-shinspear" name="Shining Spear Wargear" description="+1 Wound. Gains Heavy Aspect Armour (replacing Aspect Armour), Laser Lance, Shuriken Pistol, Skyrunner Jetbike. May replace Laser Lance with: Power Weapon (free) or Star Lance (+15 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-strkscorp"  name="Striking Scorpion (+25 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="25"/></costs><ruleLinks><ruleLink id="rl-ae-aspscorp"       targetId="sr-aspscorp"     name="Aspect Shrine (Striking Scorpion)"/><ruleLink id="rl-ae-brutambush"    targetId="sr-brutambush"   name="Brutal Ambush"/><ruleLink id="rl-ae-infiltrate"    targetId="sr-infiltrate"   name="Infiltrate"/><ruleLink id="rl-ae-mtc"           targetId="sr-mtc"          name="Move Through Cover"/><ruleLink id="rl-ae-stalker"       targetId="sr-stalker"      name="Stalker"/><ruleLink id="rl-ae-fleet2b"       targetId="sr-fleet2"       name="Fleet (2)"/></ruleLinks><rules><rule id="ru-ae-strkscorp" name="Striking Scorpion Wargear" description="Gains Heavy Aspect Armour (replacing Aspect Armour), Shuriken Pistol, Scorpion Chainsword, Mandiblaster. May replace Shuriken Pistol with: Biting Blade (+10 pts) or Scorpion's Claw (+20 pts). May replace Scorpion Chainsword and Shuriken Pistol with Two Chainsabres (+10 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-swoophawk"  name="Swooping Hawk (+20 pts)"    type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="20"/></costs><ruleLinks><ruleLink id="rl-ae-aspswoophawk"  targetId="sr-aspswoophawk"  name="Aspect Shrine (Swooping Hawk)"/><ruleLink id="rl-ae-heraldvic"    targetId="sr-heraldvic"    name="Herald of Victory"/><ruleLink id="rl-ae-skyleap"       targetId="sr-skyleap"      name="Skyleap"/><ruleLink id="rl-ae-skystrike"     targetId="sr-skystrike"    name="Skystrike"/></ruleLinks><rules><rule id="ru-ae-swoophawk" name="Swooping Hawk Wargear" description="Gains Swooping Hawk Wings, Hawk Lasblaster, Haywire Grenades, Grenade Pack. May replace Hawk Lasblaster with: Hawk's Talon (+10 pts) or Sunrifle (+15 pts)."/></rules></selectionEntry>
                <selectionEntry id="el-ae-shrine-warpspider" name="Warp Spider (+20 pts)"      type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="20"/></costs><ruleLinks><ruleLink id="rl-ae-aspwarpspid"   targetId="sr-aspwarpspid"   name="Aspect Shrine (Warp Spider)"/><ruleLink id="rl-ae-flickerjump"   targetId="sr-flickerjump"   name="Flickerjump"/><ruleLink id="rl-ae-hitrun"        targetId="sr-hitrun"       name="Hit and Run"/><ruleLink id="rl-ae-firingp2"      targetId="sr-firingp2"     name="Firing Protocols (2)"/><ruleLink id="rl-ae-ironresolve"   targetId="sr-ironresolve"   name="Iron Resolve"/></ruleLinks><rules><rule id="ru-ae-warpspider" name="Warp Spider Wargear" description="Gains Heavy Aspect Armour (replacing Aspect Armour), Warp Jump Generator, Death Spinner. May replace Death Spinner with: Two Death Spinners (+5 pts) or Spinneret Rifle (+15 pts). May additionally purchase Two Power Swords (+15 pts)."/></rules></selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
        </selectionEntry>
      </selectionEntries>
    </selectionEntry>

