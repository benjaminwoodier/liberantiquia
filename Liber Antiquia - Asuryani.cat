                <selectionEntry id="el-autarch-opt-powersword"   name="Power Weapon (+10 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><profiles><profile id="pr-autarch-powersword"   name="Power Sword" typeId="pt-melee" profileId="sp-powersword"/></profiles></selectionEntry>
                <selectionEntry id="el-autarch-opt-charnabal"    name="Charnabal Weapon (+10 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><rules><rule id="ru-autarch-charnabal" name="Charnabal Weapon" description="May select Charnabal Sabre, Tabar, or Glaive — see Armoury."/></rules></selectionEntry>
