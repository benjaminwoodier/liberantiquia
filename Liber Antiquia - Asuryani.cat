<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue xmlns="http://www.battlescribe.net/schema/catalogueSchema"
  library="false"
  id="la-asuryani-001"
  name="[Antiquia] Asuryani"
  gameSystemId="66e4-4610-1d0e-3c25"
  gameSystemRevision="2001"
  revision="1"
  battleScribeVersion="2.03"
  type="catalogue">

  <!-- ============================================================ -->
  <!-- PUBLICATIONS                                                  -->
  <!-- ============================================================ -->
  <publications>
    <publication id="a368-64f0-10c7-la01" name="Liber Antiquia v1.6" shortName="LA"/>
  </publications>

  <!-- ============================================================ -->
  <!-- COST TYPES                                                    -->
  <!-- ============================================================ -->
  <costTypes>
    <costType id="la-cost-pts" name="Pts" defaultCostLimit="-1"/>
  </costTypes>

  <!-- ============================================================ -->
  <!-- PROFILE TYPES                                                 -->
  <!-- The characteristic typeIds here mirror the existing HH2e     -->
  <!-- system so stat blocks render consistently.                    -->
  <!-- ============================================================ -->
  <profileTypes>

    <!-- Unit stat block: M WS BS S T W I A Ld Sv + Unit Type -->
    <profileType id="la-pt-unit" name="Unit">
      <characteristicTypes>
        <characteristicType id="la-ct-m"   name="Move"/>
        <characteristicType id="la-ct-ws"  name="WS"/>
        <characteristicType id="la-ct-bs"  name="BS"/>
        <characteristicType id="la-ct-s"   name="S"/>
        <characteristicType id="la-ct-t"   name="T"/>
        <characteristicType id="la-ct-w"   name="W"/>
        <characteristicType id="la-ct-i"   name="I"/>
        <characteristicType id="la-ct-a"   name="A"/>
        <characteristicType id="la-ct-ld"  name="Ld"/>
        <characteristicType id="la-ct-sv"  name="Save"/>
        <characteristicType id="la-ct-ut"  name="Unit Type"/>
      </characteristicTypes>
    </profileType>

    <!-- Ranged weapon: Range Str AP Type -->
    <profileType id="la-pt-ranged" name="Ranged Weapon">
      <characteristicTypes>
        <characteristicType id="la-ct-rng"  name="Range"/>
        <characteristicType id="la-ct-rstr" name="Str"/>
        <characteristicType id="la-ct-rap"  name="AP"/>
        <characteristicType id="la-ct-rtyp" name="Type"/>
      </characteristicTypes>
    </profileType>

    <!-- Melee weapon: Range Str AP Type (same fields, separate type for clarity) -->
    <profileType id="la-pt-melee" name="Melee Weapon">
      <characteristicTypes>
        <characteristicType id="la-ct-mng"  name="Range"/>
        <characteristicType id="la-ct-mstr" name="Str"/>
        <characteristicType id="la-ct-map"  name="AP"/>
        <characteristicType id="la-ct-mtyp" name="Type"/>
      </characteristicTypes>
    </profileType>

    <!-- Special rule / ability: just a description field -->
    <profileType id="la-pt-rule" name="Special Rule">
      <characteristicTypes>
        <characteristicType id="la-ct-rdesc" name="Description"/>
      </characteristicTypes>
    </profileType>

  </profileTypes>

  <!-- ============================================================ -->
  <!-- CATEGORY ENTRIES                                             -->
  <!-- ============================================================ -->
  <categoryEntries>
    <categoryEntry id="la-cat-hq"       name="HQ"/>
    <categoryEntry id="la-cat-elites"   name="Elites"/>
    <categoryEntry id="la-cat-troops"   name="Troops"/>
    <categoryEntry id="la-cat-fa"       name="Fast Attack"/>
    <categoryEntry id="la-cat-hs"       name="Heavy Support"/>
    <categoryEntry id="la-cat-low"      name="Lords of War"/>
    <categoryEntry id="la-cat-fort"     name="Fortification"/>
    <categoryEntry id="la-cat-dt"       name="Dedicated Transport"/>
    <!-- Sub-type tags used for rule interactions -->
    <categoryEntry id="la-cat-asuryani" name="Asuryani"/>
    <categoryEntry id="la-cat-character" name="Character"/>
    <categoryEntry id="la-cat-psyker"   name="Psyker"/>
    <categoryEntry id="la-cat-vehicle"  name="Vehicle"/>
    <categoryEntry id="la-cat-infantry" name="Infantry"/>
    <categoryEntry id="la-cat-cavalry"  name="Cavalry"/>
    <categoryEntry id="la-cat-line"     name="Line"/>
    <categoryEntry id="la-cat-wraith"   name="Wraith Sub-type"/>
    <categoryEntry id="la-cat-gravplat" name="Grav-Platform Sub-type"/>
  </categoryEntries>

  <!-- ============================================================ -->
  <!-- FORCE ENTRIES — Crusade Force Organisation Chart             -->
  <!-- ============================================================ -->
  <forceEntries>
    <forceEntry id="la-force-crusade" name="Crusade Force Organisation Chart" hidden="false">
      <categoryLinks>
        <categoryLink id="la-fl-hq"     targetId="la-cat-hq"    name="HQ"           primary="false">
          <constraints>
            <constraint id="la-fl-hq-min" type="min" value="1" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-hq-max" type="max" value="2" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
        <categoryLink id="la-fl-elites" targetId="la-cat-elites" name="Elites"       primary="false">
          <constraints>
            <constraint id="la-fl-el-min" type="min" value="0" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-el-max" type="max" value="3" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
        <categoryLink id="la-fl-troops" targetId="la-cat-troops" name="Troops"       primary="false">
          <constraints>
            <constraint id="la-fl-tr-min" type="min" value="2" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-tr-max" type="max" value="6" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
        <categoryLink id="la-fl-fa"     targetId="la-cat-fa"    name="Fast Attack"   primary="false">
          <constraints>
            <constraint id="la-fl-fa-min" type="min" value="0" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-fa-max" type="max" value="3" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
        <categoryLink id="la-fl-hs"     targetId="la-cat-hs"    name="Heavy Support" primary="false">
          <constraints>
            <constraint id="la-fl-hs-min" type="min" value="0" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-hs-max" type="max" value="3" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
        <categoryLink id="la-fl-low"    targetId="la-cat-low"   name="Lords of War"  primary="false">
          <constraints>
            <constraint id="la-fl-lw-min" type="min" value="0" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-lw-max" type="max" value="1" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
        <categoryLink id="la-fl-fort"   targetId="la-cat-fort"  name="Fortification" primary="false">
          <constraints>
            <constraint id="la-fl-ft-min" type="min" value="0" field="selections" scope="force" shared="true"/>
            <constraint id="la-fl-ft-max" type="max" value="1" field="selections" scope="force" shared="true"/>
          </constraints>
        </categoryLink>
      </categoryLinks>
    </forceEntry>
  </forceEntries>

  <!-- ============================================================ -->
  <!-- SHARED RULES                                                 -->
  <!-- Universal special rules referenced across multiple units.    -->
  <!-- ============================================================ -->
  <sharedRules>

    <rule id="la-sr-fleet1"   name="Fleet (1)"
      description="This unit may re-roll a single dice when determining Run distance or Charge distance."/>
    <rule id="la-sr-fleet2"   name="Fleet (2)"
      description="This unit may re-roll up to two dice when determining Run distance or Charge distance."/>
    <rule id="la-sr-ic"       name="Independent Character"
      description="This model may join and leave units as per the Independent Character rules in the core rulebook."/>
    <rule id="la-sr-fearless" name="Fearless"
      description="This unit automatically passes Morale checks and Pinning tests, and may not choose to fail a Morale check."/>
    <rule id="la-sr-stubborn" name="Stubborn"
      description="This unit uses its unmodified Leadership when making Morale checks."/>
    <rule id="la-sr-relentless" name="Relentless"
      description="This unit may fire Heavy or Ordnance weapons and count as Stationary even if it moved in the preceding Movement phase."/>
    <rule id="la-sr-infiltrate" name="Infiltrate"
      description="Units with this rule may be set up using the Infiltrate deployment rules as described in the core rulebook."/>
    <rule id="la-sr-scout"    name="Scout"
      description="Units with this rule may make a Scout move before the first Game Turn as described in the core rulebook."/>
    <rule id="la-sr-mtc"      name="Move Through Cover"
      description="When this unit makes a Move through Difficult Terrain, it rolls an extra D6 and discards the lowest result."/>
    <rule id="la-sr-shroud4"  name="Shrouded (4+)"
      description="Models in this unit may take a 4+ Damage Mitigation roll against any Wound or Hull Point of damage suffered."/>
    <rule id="la-sr-shroud5"  name="Shrouded (5+)"
      description="Models in this unit may take a 5+ Damage Mitigation roll against any Wound or Hull Point of damage suffered."/>
    <rule id="la-sr-fnp5"     name="Feel No Pain (5+)"
      description="Models in this unit may take a 5+ Feel No Pain roll against any Wound suffered that is not caused by Instant Death."/>
    <rule id="la-sr-aw3"      name="Adamantium Will (3+)"
      description="Enemy Psykers within 18&quot; of a model with this rule must reduce their Leadership by -3 when making Psychic Checks. In addition this model gains a 3+ save against the effects of Psychic Powers targeting it."/>
    <rule id="la-sr-batfoc"   name="Battle Focus"
      description="A unit composed entirely of models with this rule may choose to Run in the Controlling Player's Movement Phase and still shoot in the following Shooting Phase. If they do, all shooting attacks are resolved at Ballistic Skill 2."/>
    <rule id="la-sr-legfall"  name="Legacies of the Fall"
      description="This model has the Hatred (Daemons) Special Rule. In addition, a unit with this rule suffers a -1 penalty to their Leadership whilst locked in combat with at least one model with the Daemon Unit Type."/>
    <rule id="la-sr-pfarseer" name="Path of the Farseer"
      description="This model gains the Runes of Fate Psychic Discipline as well as the Divination, Telepathy, and Thaumaturgy Psychic Disciplines. See Liber Antiquia p.24 and the core rulebook p.322."/>
    <rule id="la-sr-poc"      name="Path of Command"
      description="If your army contains any models with this rule in the Primary Detachment, one must be your Warlord. Units from the same Detachment sharing the same Aspect Shrine (X) rule as the Warlord gain the Line sub-type."/>
    <rule id="la-sr-rnwarding" name="Runes of Warding"
      description="Any enemy model within 18&quot; and line of sight of this model must reduce its Leadership by -3 when making Psychic Checks. This modifier is not cumulative and no model may suffer penalties from more than one model with this rule."/>
    <rule id="la-sr-rnwitnessing" name="Runes of Witnessing"
      description="Once per Game Turn, this model may re-roll any number of dice when making a Psychic Check."/>
    <rule id="la-sr-psym2"    name="Psychic Mastery (2)"
      description="This model may cast up to 2 Psychic Powers per phase."/>
    <rule id="la-sr-deepstrike" name="Deep Strike"
      description="This unit may be held in Reserve and arrive via Deep Strike Assault as described in the core rulebook."/>
    <rule id="la-sr-hitrun"   name="Hit &amp; Run"
      description="This unit may make a Hit &amp; Run move as described in the core rulebook."/>
    <rule id="la-sr-hamwrath1" name="Hammer of Wrath (1)"
      description="Each model with this rule makes 1 additional automatic hit at their unmodified Strength with no AP when they make a successful Charge."/>
    <rule id="la-sr-firingp2" name="Firing Protocols (2)"
      description="Once per turn, a model with this rule may fire a second time with a single Assault or Pistol weapon it is equipped with, at BS 1."/>
    <rule id="la-sr-bh1"      name="Battle-Hardened (1)"
      description="This unit may re-roll a single To Hit roll per phase."/>
    <rule id="la-sr-support"  name="Support Squad"
      description="This unit may not be selected as a Compulsory Troops choice."/>
    <rule id="la-sr-bulky2"   name="Bulky (2)"
      description="Each model with this rule takes up 2 spaces in a Transport rather than 1."/>

  </sharedRules>

