    <selectionEntry id="ge-gravstarcannon"   name="Gravis Starcannon"    type="upgrade" hidden="false"><profiles><profile id="pr-gravstarcannon"   name="Gravis Starcannon"    typeId="pt-ranged" profileId="sp-gravstarcannon"/></profiles></selectionEntry>
