                <selectionEntry id="el-ws-turret-gsl"  name="Gravis Scatter Laser (+5 pts)"             type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="5"/></costs><profiles><profile id="pr-ws-turret-gsl"  name="Gravis Scatter Laser"           typeId="pt-ranged" profileId="sp-gravscatlaser"/></profiles></selectionEntry>
