                <selectionEntry id="el-autarch-shrine-shinspear"  name="Shining Spear (+25 pts)"   type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="25"/></costs><ruleLinks><ruleLink id="rl-autarch-aspspear"     targetId="sr-aspspear"     name="Aspect Shrine (Shining Spear)"/><ruleLink id="rl-autarch-monsthunt"   targetId="sr-monsterhunt"  name="Monster Hunter"/><ruleLink id="rl-autarch-pathfinder"   targetId="sr-pathfinder"   name="Pathfinder"/><ruleLink id="rl-autarch-shroud4b"    targetId="sr-shroud4"     name="Shrouded (4+)"/><ruleLink id="rl-autarch-relentless3"  targetId="sr-relentless"  name="Relentless"/><ruleLink id="rl-autarch-firingp3"    targetId="sr-firingp3"    name="Firing Protocols (3)"/><ruleLink id="rl-autarch-outflank"    targetId="sr-outflank"    name="Outflank"/></ruleLinks><rules><rule id="ru-autarch-shinspear-w" name="Shining Spear Wargear" description="+1 Wound. Gains: Laser Lance, Shuriken Pistol, Skyrunner Jetbike. May replace Laser Lance with Power Weapon (free) or Star Lance (+15 pts)."/></rules></selectionEntry>
