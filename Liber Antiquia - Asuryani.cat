    <profileType id="pt-ranged" name="Ranged Weapon">
      <characteristicTypes>
        <characteristicType id="ct-rng"  name="Range"/>
        <characteristicType id="ct-rstr" name="Str"/>
        <characteristicType id="ct-rap"  name="AP"/>
        <characteristicType id="ct-rtyp" name="Type"/>
