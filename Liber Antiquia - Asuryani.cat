        <categoryLink id="cl-ae-asuryani"  targetId="cat-asuryani"  primary="false"/>
        <categoryLink id="cl-ae-infantry"  targetId="cat-infantry"  primary="false"/>
        <categoryLink id="cl-ae-character" targetId="cat-character" primary="false"/>
      </categoryLinks>
      <constraints>
