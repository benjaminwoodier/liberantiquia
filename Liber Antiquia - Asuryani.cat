                <selectionEntry id="el-autarch-opt-starglaive"   name="Star Glaive (+20 pts)"  type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="20"/></costs><profiles><profile id="pr-autarch-starglaive"   name="Star Glaive"   typeId="pt-melee" profileId="sp-starglaive"/></profiles></selectionEntry>
