    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- WRAITHLORD CONCLAVE — 180 pts (1 model)                               -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <selectionEntry id="u-wraithlord" name="Wraithlord Conclave" type="unit" hidden="false" page="74" publicationId="pub-la01">
      <categoryLinks>
        <categoryLink id="cl-wl-hs"       targetId="cat-hs"       primary="true"/>
        <categoryLink id="cl-wl-asuryani" targetId="cat-asuryani" primary="false"/>
        <categoryLink id="cl-wl-automata" targetId="cat-automata" primary="false"/>
        <categoryLink id="cl-wl-wraith"   targetId="cat-wraith"   primary="false"/>
      </categoryLinks>
      <costs><cost name="Pts" typeId="ct-pts" value="180"/></costs>
      <profiles>
        <profile id="stat-wl" name="Wraithlord" typeId="pt-unit">
          <characteristics>
            <characteristic typeId="ct-m"  name="Move">8</characteristic>
            <characteristic typeId="ct-ws" name="WS">5</characteristic>
            <characteristic typeId="ct-bs" name="BS">5</characteristic>
            <characteristic typeId="ct-s"  name="S">8</characteristic>
            <characteristic typeId="ct-t"  name="T">8</characteristic>
            <characteristic typeId="ct-w"  name="W">5</characteristic>
            <characteristic typeId="ct-i"  name="I">4</characteristic>
            <characteristic typeId="ct-a"  name="A">3</characteristic>
            <characteristic typeId="ct-ld" name="Ld">8</characteristic>
            <characteristic typeId="ct-sv" name="Save">3+</characteristic>
            <characteristic typeId="ct-ut" name="Unit Type">Automata (Asuryani, Wraith)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntries>
        <selectionEntry id="u-wl-model" name="Wraithlord" type="model" hidden="false">
          <constraints>
            <constraint id="con-wl-model-min" type="min" value="1" field="selections" scope="parent" shared="true"/>
            <constraint id="con-wl-model-max" type="max" value="3" field="selections" scope="parent" shared="true"/>
          </constraints>
          <costs><cost name="Pts" typeId="ct-pts" value="180"/></costs>
          <entryLinks>
            <entryLink id="el-wl-powerfield" name="Power Field" type="selectionEntry" targetId="ge-powerfield" hidden="false"><constraints><constraint id="con-wl-pf-min" type="min" value="1" field="selections" scope="parent" shared="true"/><constraint id="con-wl-pf-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints></entryLink>
          </entryLinks>
          <ruleLinks>
            <ruleLink id="rl-wl-wraithconc"    targetId="sr-wraithconc"    name="Wraith Conclave"/>
            <ruleLink id="rl-wl-itwillnotdie6" targetId="sr-itwillnotdie6" name="It Will Not Die (6+)"/>
            <ruleLink id="rl-wl-wraithtype"    targetId="sr-wraithtypes"   name="Wraith Sub-type"/>
            <ruleLink id="rl-wl-legfall"       targetId="sr-legfall"       name="Legacies of the Fall"/>
          </ruleLinks>
          <!-- Two Wraith Gauntlets by default; can replace one with Wraithsword -->
          <selectionEntryGroups>
            <selectionEntryGroup id="seg-wl-arm1" name="Arm 1" defaultSelectionEntryId="el-wl-arm1-gauntlet">
              <constraints><constraint id="con-wl-arm1-min" type="min" value="1" field="selections" scope="parent" shared="true"/><constraint id="con-wl-arm1-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints>
              <selectionEntries>
                <selectionEntry id="el-wl-arm1-gauntlet" name="Wraith Gauntlet with Shuriken Catapult (included)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="0"/></costs><profiles><profile id="pr-wl-arm1g" name="Wraith Gauntlet" typeId="pt-melee" profileId="sp-wraithgauntlet"/><profile id="pr-wl-arm1g-cat" name="Shuriken Catapult (built-in)" typeId="pt-ranged" profileId="sp-shurikencat"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-arm1-wraithsword" name="Wraithsword with Shuriken Catapult (+15 pts)"   type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><profiles><profile id="pr-wl-arm1ws-p" name="Wraithsword (Piercing Blow)"  typeId="pt-melee" profileId="sp-wraithsword-p"/><profile id="pr-wl-arm1ws-s" name="Wraithsword (Sweeping Strike)" typeId="pt-melee" profileId="sp-wraithsword-s"/><profile id="pr-wl-arm1ws-cat" name="Shuriken Catapult (built-in)" typeId="pt-ranged" profileId="sp-shurikencat"/></profiles></selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
            <selectionEntryGroup id="seg-wl-arm2" name="Arm 2" defaultSelectionEntryId="el-wl-arm2-gauntlet">
              <constraints><constraint id="con-wl-arm2-min" type="min" value="1" field="selections" scope="parent" shared="true"/><constraint id="con-wl-arm2-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints>
              <selectionEntries>
                <selectionEntry id="el-wl-arm2-gauntlet"   name="Wraith Gauntlet with Shuriken Catapult (included)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="0"/></costs><profiles><profile id="pr-wl-arm2g" name="Wraith Gauntlet" typeId="pt-melee" profileId="sp-wraithgauntlet"/><profile id="pr-wl-arm2g-cat" name="Shuriken Catapult (built-in)" typeId="pt-ranged" profileId="sp-shurikencat"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-arm2-wraithsword" name="Wraithsword with Shuriken Catapult (+15 pts)"   type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><profiles><profile id="pr-wl-arm2ws-p" name="Wraithsword (Piercing Blow)"  typeId="pt-melee" profileId="sp-wraithsword-p"/><profile id="pr-wl-arm2ws-s" name="Wraithsword (Sweeping Strike)" typeId="pt-melee" profileId="sp-wraithsword-s"/><profile id="pr-wl-arm2ws-cat" name="Shuriken Catapult (built-in)" typeId="pt-ranged" profileId="sp-shurikencat"/></profiles></selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
            <!-- Optional ranged weapon slots (up to 2 total per model) -->
            <selectionEntryGroup id="seg-wl-ranged1" name="Optional Ranged Weapon 1">
              <constraints><constraint id="con-wl-r1-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints>
              <selectionEntries>
                <selectionEntry id="el-wl-r1-sc"   name="Shuriken Cannon (+5 pts)"            type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="5"/></costs><profiles><profile id="pr-wl-r1-sc"   name="Shuriken Cannon"         typeId="pt-ranged" profileId="sp-shurikencan"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r1-sl"   name="Scatter Laser (+5 pts)"              type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="5"/></costs><profiles><profile id="pr-wl-r1-sl"   name="Scatter Laser"           typeId="pt-ranged" profileId="sp-scatlaser"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r1-star"  name="Starcannon (+10 pts)"               type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><profiles><profile id="pr-wl-r1-star"  name="Starcannon"              typeId="pt-ranged" profileId="sp-starcannon"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r1-aml"   name="Aeldari Missile Launcher (+10 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><profiles><profile id="pr-wl-r1-aml-sun" name="AML (Sunburst)" typeId="pt-ranged" profileId="sp-aml-sunburst"/><profile id="pr-wl-r1-aml-shot" name="AML (Starshot)" typeId="pt-ranged" profileId="sp-aml-starshot"/><profile id="pr-wl-r1-aml-hawk" name="AML (Starhawk)" typeId="pt-ranged" profileId="sp-aml-starhawk"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r1-bl"    name="Bright Lance (+15 pts)"             type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><profiles><profile id="pr-wl-r1-bl"    name="Bright Lance"            typeId="pt-ranged" profileId="sp-brightlance"/></profiles></selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
            <selectionEntryGroup id="seg-wl-ranged2" name="Optional Ranged Weapon 2">
              <constraints><constraint id="con-wl-r2-max" type="max" value="1" field="selections" scope="parent" shared="true"/></constraints>
              <selectionEntries>
                <selectionEntry id="el-wl-r2-sc"   name="Shuriken Cannon (+5 pts)"            type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="5"/></costs><profiles><profile id="pr-wl-r2-sc"   name="Shuriken Cannon"         typeId="pt-ranged" profileId="sp-shurikencan"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r2-sl"   name="Scatter Laser (+5 pts)"              type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="5"/></costs><profiles><profile id="pr-wl-r2-sl"   name="Scatter Laser"           typeId="pt-ranged" profileId="sp-scatlaser"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r2-star"  name="Starcannon (+10 pts)"               type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><profiles><profile id="pr-wl-r2-star"  name="Starcannon"              typeId="pt-ranged" profileId="sp-starcannon"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r2-aml"   name="Aeldari Missile Launcher (+10 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><profiles><profile id="pr-wl-r2-aml-sun" name="AML (Sunburst)" typeId="pt-ranged" profileId="sp-aml-sunburst"/><profile id="pr-wl-r2-aml-shot" name="AML (Starshot)" typeId="pt-ranged" profileId="sp-aml-starshot"/><profile id="pr-wl-r2-aml-hawk" name="AML (Starhawk)" typeId="pt-ranged" profileId="sp-aml-starhawk"/></profiles></selectionEntry>
                <selectionEntry id="el-wl-r2-bl"    name="Bright Lance (+15 pts)"             type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><profiles><profile id="pr-wl-r2-bl"    name="Bright Lance"            typeId="pt-ranged" profileId="sp-brightlance"/></profiles></selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
            <!-- Built-in Shuriken Catapult on Gauntlet can be replaced -->
            <selectionEntryGroup id="seg-wl-gauntletcat" name="Replace Built-in Shuriken Catapult (per arm, if keeping Gauntlet)">
              <rules><rule id="ru-wl-gauntletcat" name="Gauntlet Catapult Replacement" description="An in-built Shuriken Catapult on either a Wraith Gauntlet or Wraithsword may be replaced with a Flamer (+5 pts) or Fusion Gun (+10 pts)."/></rules>
            </selectionEntryGroup>
          </selectionEntryGroups>
        </selectionEntry>
      </selectionEntries>
    </selectionEntry>

