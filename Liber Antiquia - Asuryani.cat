<sharedSelectionEntries>
    <!-- ══ ARMOUR ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="ge-mesharmour"       name="Mesh Armour"          type="upgrade" hidden="false"><rules><rule id="ru-mesharmour"       name="Mesh Armour"          description="Confers a 5+ Armour Save."/></rules></selectionEntry>
    <selectionEntry id="ge-heavymesh"        name="Heavy Mesh Armour"    type="upgrade" hidden="false"><rules><rule id="ru-heavymesh"        name="Heavy Mesh Armour"    description="Confers a 4+ Armour Save."/></rules></selectionEntry>
    <selectionEntry id="ge-aspectarmour"     name="Aspect Armour"        type="upgrade" hidden="false"><rules><rule id="ru-aspectarmour"     name="Aspect Armour"        description="Confers a 4+ Armour Save and a 5+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-heavyaspect"      name="Heavy Aspect Armour"  type="upgrade" hidden="false"><rules><rule id="ru-heavyaspect"      name="Heavy Aspect Armour"  description="Confers a 3+ Armour Save and a 5+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-phoenixarmour"    name="Phoenix Armour"       type="upgrade" hidden="false"><rules><rule id="ru-phoenixarmour"    name="Phoenix Armour"       description="Confers a 2+ Armour Save and a 4+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-runearmour"       name="Rune Armour"          type="upgrade" hidden="false"><rules><rule id="ru-runearmour"       name="Rune Armour"          description="Confers a 4+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-holosuit"         name="Holo-Suit"            type="upgrade" hidden="false"><rules><rule id="ru-holosuit"         name="Holo-Suit"            description="Confers a 4+ Invulnerable Save."/></rules></selectionEntry>
    <!-- ══ SHIELDS ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="ge-forceshield"      name="Forceshield"          type="upgrade" hidden="false"><rules><rule id="ru-forceshield"      name="Forceshield"          description="Confers a 5+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-impforceshield"   name="Improved Forceshield" type="upgrade" hidden="false"><rules><rule id="ru-impforceshield"   name="Improved Forceshield" description="Confers a 4+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-holofields"       name="Holo-Fields"          type="upgrade" hidden="false"><rules><rule id="ru-holofields"       name="Holo-Fields"          description="Confers a 5+ Invulnerable Save against Shooting Attacks unless Immobilised."/></rules></selectionEntry>
    <selectionEntry id="ge-impholofields"    name="Improved Holo-Fields" type="upgrade" hidden="false"><rules><rule id="ru-impholofields"    name="Improved Holo-Fields" description="Confers a 4+ Invulnerable Save against Shooting Attacks unless Immobilised."/></rules></selectionEntry>
    <selectionEntry id="ge-gloomfield"       name="Gloom Field"          type="upgrade" hidden="false"><rules><rule id="ru-gloomfield"       name="Gloom Field"          description="A unit containing at least one model with a Gloom Field has Shrouded (5+)."/></rules></selectionEntry>
    <selectionEntry id="ge-powerfield"       name="Power Field"          type="upgrade" hidden="false"><rules><rule id="ru-powerfield"       name="Power Field"          description="Confers a 5+ Invulnerable Save. Models with a Wounds Characteristic that suffer an unsaved Wound with Instant Death lose D3 Wounds instead of one. When this model loses its last Wound/Hull Point, all models within D6&quot; suffer an automatic Str 8, AP- Hit."/></rules></selectionEntry>
    <selectionEntry id="ge-scattershield"    name="Scattershield"        type="upgrade" hidden="false"><rules><rule id="ru-scattershield"    name="Scattershield"        description="Confers a 5+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-serpentscale"     name="Serpentscale Shield"  type="upgrade" hidden="false"><rules><rule id="ru-serpentscale"     name="Serpentscale Shield"  description="A unit with at least one model with a Serpentscale Shield has a 5+ Invulnerable Save against all incoming Shooting Attacks."/></rules></selectionEntry>
    <selectionEntry id="ge-wraithformshield" name="Wraithform Shield"    type="upgrade" hidden="false"><rules><rule id="ru-wraithformshield" name="Wraithform Shield"    description="Confers a 6+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="ge-wraithshield"     name="Wraithshield"         type="upgrade" hidden="false"><rules><rule id="ru-wraithshield"     name="Wraithshield"         description="Confers a 4+ Invulnerable Save. Models that suffer an unsaved Wound with Instant Death lose D3 Wounds instead of one. When this model loses its last Wound/Hull Point, all models within D6&quot; suffer an automatic Str 8, AP- Hit."/></rules></selectionEntry>
    <selectionEntry id="ge-waveserpentshield" name="Wave Serpent Shield" type="upgrade" hidden="false">
      <rules><rule id="ru-waveserpentshield" name="Wave Serpent Shield"  description="Confers a 6+ Invulnerable Save against Shooting on Front and Side Armour. Once per game, may make a Shield Blast: Str 6, AP-, Assault 8, 12&quot;, Ignores Cover, Concussive (2), One Use. After use, the 6+ save is lost for the remainder of the battle."/></rules>
      <profiles><profile id="pr-shieldblast" name="Wave Serpent Shield Blast" typeId="pt-ranged" profileId="sp-shieldblast"/></profiles>
    </selectionEntry>
    <selectionEntry id="ge-miragelaunch"     name="Mirage Launchers"     type="upgrade" hidden="false"><rules><rule id="ru-miragelaunch"     name="Mirage Launchers"     description="The range between an attacking unit and this unit is considered 6&quot; further than actual. Models with the Primarch Unit Type ignore this. When attacked by Barrage weapons, this unit is always treated as out of line of sight when scattering."/></rules></selectionEntry>
    <!-- ══ GRENADES ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="ge-plasmagrenades"   name="Plasma Grenades"      type="upgrade" hidden="false"><rules><rule id="ru-plasmagrenades"   name="Plasma Grenades"      description="This unit attacks at normal Initiative after charging through Difficult or Dangerous Terrain. A model in base contact with a Vehicle, Dreadnought, Automata, Building, or Fortification may inflict one automatic Str 5, AP 4 Hit with Breaching (6+) at Initiative Step 1 instead of attacking normally."/></rules></selectionEntry>
    <selectionEntry id="ge-haywiregren"      name="Haywire Grenades"     type="upgrade" hidden="false">
      <profiles><profile id="pr-haywiregrenm" name="Haywire Grenade" typeId="pt-melee" profileId="sp-haywiregrenm"/></profiles>
    </selectionEntry>
    <selectionEntry id="ge-meltabombs"       name="Melta Bombs"          type="upgrade" hidden="false">
      <profiles><profile id="pr-meltabomb" name="Melta Bomb" typeId="pt-melee" profileId="sp-meltabomb"/></profiles>
    </selectionEntry>
    <selectionEntry id="ge-vortexgrenade"    name="Vortex Grenade"       type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="25"/></costs>
      <profiles><profile id="pr-vortexgrenade" name="Vortex Grenade" typeId="pt-ranged" profileId="sp-vortexgrenade"/></profiles>
    </selectionEntry>
    <!-- ══ JETBIKES ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="ge-skyrunnerjetbike" name="Skyrunner Jetbike"    type="upgrade" hidden="false">
      <rules><rule id="ru-skyrunnerjetbike" name="Skyrunner Jetbike"     description="Has Twin-Linked Shuriken Catapult. At the start of the Charge Sub-Phase, this model may move up to its unmodified Initiative Characteristic instead of declaring a Charge. Changes Unit Type to Cavalry (Antigrav), Move to 18. Grants: Fleet (2), Firing Protocols (2), Hit and Run, Hammer of Wrath (1), Relentless, Battle-Hardened (1), Shrouded (5+), Deep Strike."/></rules>
      <profiles><profile id="pr-skyrunner-cat" name="Skyrunner Jetbike (Shuriken Catapult)" typeId="pt-ranged" profileId="sp-shurikencat"/></profiles>
    </selectionEntry>
    <selectionEntry id="ge-raptorjetbike"    name="Raptor Jetbike"       type="upgrade" hidden="false">
      <rules><rule id="ru-raptorjetbike"    name="Raptor Jetbike"        description="Has Scatter Laser. Changes Unit Type to Cavalry (Antigrav), Move to 18. Grants: Fleet (2), Firing Protocols (3), Hit and Run, Hammer of Wrath (1), Relentless, Scout, Infiltrate, Battle-Hardened (1), Shrouded (5+), Deep Strike."/></rules>
      <profiles><profile id="pr-raptor-scat" name="Raptor Jetbike (Scatter Laser)" typeId="pt-ranged" profileId="sp-scatlaser"/></profiles>
    </selectionEntry>
    <selectionEntry id="ge-vyperjetbike"     name="Vyper Jetbike"        type="upgrade" hidden="false">
      <rules><rule id="ru-vyperjetbike"     name="Vyper Jetbike"         description="Has Twin-Linked Shuriken Catapult and Shuriken Cannon. Changes Unit Type to Cavalry (Antigrav), Move to 16. Grants: Fleet (2), Firing Protocols (2), Hit and Run, Hammer of Wrath (2), Relentless, Shrouded (5+), Deep Strike."/></rules>
      <profiles>
        <profile id="pr-vyper-cat" name="Vyper Jetbike (Twin-Linked Shuriken Catapult)" typeId="pt-ranged" profileId="sp-shurikencat"/>
        <profile id="pr-vyper-can" name="Vyper Jetbike (Shuriken Cannon)"               typeId="pt-ranged" profileId="sp-shurikencan"/>
      </profiles>
    </selectionEntry>
    <selectionEntry id="ge-starweaverskimmer" name="Starweaver Skimmer"  type="upgrade" hidden="false">
      <rules><rule id="ru-starweaverskimmer" name="Starweaver Skimmer"   description="Has 2 Shuriken Cannons. At the start of the Charge Sub-Phase, this model may move up to its unmodified Initiative instead of declaring a Charge. Changes Unit Type to Cavalry (Antigrav), Move to 16, gains 3+ Armour Save. Grants: Fleet (2), Firing Protocols (2), Hit and Run, Hammer of Wrath (1), Relentless, Shrouded (5+), Deep Strike."/></rules>
      <profiles>
        <profile id="pr-stw-can1" name="Starweaver Skimmer (Shuriken Cannon 1)" typeId="pt-ranged" profileId="sp-shurikencan"/>
        <profile id="pr-stw-can2" name="Starweaver Skimmer (Shuriken Cannon 2)" typeId="pt-ranged" profileId="sp-shurikencan"/>
      </profiles>
    </selectionEntry>
    <selectionEntry id="ge-skyweaverjetbike" name="Skyweaver Jetbike"    type="upgrade" hidden="false">
      <rules><rule id="ru-skyweaverjetbike" name="Skyweaver Jetbike"     description="Has Shuriken Cannon. At the start of the Charge Sub-Phase, this model may move up to its unmodified Initiative instead of declaring a Charge. Changes Unit Type to Cavalry (Antigrav), Move to 18. Grants: Fleet (2), Firing Protocols (2), Hit and Run, Hammer of Wrath (1), Relentless, Battle-Hardened (1), Shrouded (5+), Deep Strike."/></rules>
      <profiles><profile id="pr-skyw-can" name="Skyweaver Jetbike (Shuriken Cannon)" typeId="pt-ranged" profileId="sp-shurikencan"/></profiles>
    </selectionEntry>
    <!-- ══ JUMP PACKS / ENGINES ══════════════════════════════════════════════ -->
    <selectionEntry id="ge-spectrejetpack"   name="Spectre Jet Pack"     type="upgrade" hidden="false"><rules><rule id="ru-spectrejetpack"   name="Spectre Jet Pack"     description="Unit may increase Move by +7 and ignore terrain while Moving. Treats Difficult as Dangerous Terrain. After shooting, may make an additional Move of 7&quot; ignoring terrain. During movement Reactions, increases Move distance by 7. Grants Bulky (2) and Deep Strike."/></rules></selectionEntry>
    <selectionEntry id="ge-swoophawkwings"   name="Swooping Hawk Wings"  type="upgrade" hidden="false"><rules><rule id="ru-swoophawkwings"   name="Swooping Hawk Wings"  description="At start of Movement Phase or when Deep Striking, may set Move to 16&quot;. Ignores terrain while Moving/Charging. Dangerous Terrain tests still apply when beginning or ending in Dangerous Terrain. May move over friendly and enemy models. Grants Bulky (2) and Deep Strike."/></rules></selectionEntry>
    <selectionEntry id="ge-warpjumpgen"      name="Warp Jump Generator"  type="upgrade" hidden="false"><rules><rule id="ru-warpjumpgen"      name="Warp Jump Generator"  description="Unit may set Move to 14&quot;, ignoring terrain (Difficult counts as Dangerous). After shooting, may make an additional Move of 7&quot; ignoring terrain. During movement Reactions, increases Move by 7. Grants Bulky (2) and Deep Strike. Enables Flickerjump Advanced Reaction."/></rules></selectionEntry>
    <selectionEntry id="ge-revenantjumpeng"  name="Revenant Jump Engines" type="upgrade" hidden="false"><rules><rule id="ru-revenantjumpeng"  name="Revenant Jump Engines" description="At the start of the Movement Phase, this model may add +16&quot; to its Movement for that turn (move up to 32&quot;). While activated, ignores terrain while Moving and Charging (cannot end in Impassable Terrain). May move over friendly and enemy models. Cannot activate during Reactions."/></rules></selectionEntry>
    <selectionEntry id="ge-webwayshunt"      name="Webway Shunt Generator" type="upgrade" hidden="false"><rules><rule id="ru-webwayshunt"      name="Webway Shunt Generator" description="Once per game during the Movement Phase before this model moves, place the model anywhere on the board and follow the Deep Strike Assault procedure. This model has already passed its Reserve roll. Cannot charge on the same turn it activates."/></rules></selectionEntry>
    <!-- ══ VEHICLE UPGRADES ══════════════════════════════════════════════════ -->
    <selectionEntry id="ge-starengines"      name="Star Engines"         type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="15"/></costs>
      <rules><rule id="ru-starengines"      name="Star Engines"          description="This model moves an additional 3&quot; when making Movement Reactions."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-vectoredengines"  name="Vectored Engines"     type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="15"/></costs>
      <rules><rule id="ru-vectoredengines"  name="Vectored Engines"      description="When targeted by a Shooting Attack in the Opposing Player's turn, if the Reactive Player chooses to react, before any Shooting Attacks are resolved this model may immediately pivot on the spot to face any direction."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-searchlights"     name="Searchlights"         type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="5"/></costs>
      <rules><rule id="ru-searchlights"     name="Searchlights"          description="This model ignores the 24&quot; Night Fighting LoS limit when shooting. Enemy units also ignore that restriction when targeting this model. Any unit targeted by this model may be freely targeted by any other unit ignoring the Night Fighting restriction. Not a weapon; cannot be destroyed."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-spiritstones"     name="Spirit Stones"        type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="10"/></costs>
      <rules><rule id="ru-spiritstones"     name="Spirit Stones"         description="This model gains the Reinforced Sub-type."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-holofields-veh"   name="Holo-Fields (Vehicle)" type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="20"/></costs>
      <rules><rule id="ru-holofields-veh"   name="Holo-Fields"           description="Confers a 5+ Invulnerable Save against Shooting Attacks unless Immobilised."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-crystaltarget"    name="Crystal Targeting Matrix" type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="20"/></costs>
      <rules><rule id="ru-crystaltarget"    name="Crystal Targeting Matrix" description="Once per game, this model may fire a single weapon at full Ballistic Skill in the Shooting Phase after moving Flat Out."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-ghostwalkermat"   name="Ghostwalker Matrix"   type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="5"/></costs>
      <rules><rule id="ru-ghostwalkermat"   name="Ghostwalker Matrix"    description="This model has Move Through Cover. If it has the Antigrav Sub-type, it gains Pathfinder instead."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-helicaltarget"    name="Helical Targeting Array" type="upgrade" hidden="false">
      <rules><rule id="ru-helicaltarget"    name="Helical Targeting Array" description="Activate at the start of the Controlling Player's turn. Until next turn: cannot move/Run/React except Interceptor or Overwatch; may use Skyfire on all Shooting Attacks; no Shrouded saves against this model's attacks; Interceptor Reactions are free (does not cost Reaction Allotment); Vehicle may fire all weapons (not just Defensive) as part of Interceptor."/></rules>
    </selectionEntry>
    <!-- ══ EQUIPMENT ══════════════════════════════════════════════════════════ -->
    <selectionEntry id="ge-auguryscanner"    name="Augury Scanner"       type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="10"/></costs>
      <rules><rule id="ru-auguryscanner"    name="Augury Scanner"        description="Enemy models cannot Infiltrate within 18&quot; of this model. Unit ignores Night Fighting 24&quot; LoS limit when shooting. When any enemy unit deploys from Reserves, this unit may make an Interceptor Reaction for free (once per Phase, cannot exceed 3 Reactions total)."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-commbead"         name="Comm-Bead"            type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="10"/></costs>
      <rules><rule id="ru-commbead"         name="Comm-Bead"             description="While on the battlefield and not Embarked, the Controlling Player may re-roll Scatter rolls if this model has LoS to the target. The unit ignores the -1 Leadership Night Fighting penalty."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-craftstandard"    name="Craftworld Standard"  type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="10"/></costs>
      <rules><rule id="ru-craftstandard"    name="Craftworld Standard"   description="+1 Wounds score in combat. May choose to Fall Back only D6&quot; instead of 2D6&quot;. Models that would move off the battlefield edge stop 1&quot; from it."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-guidestones"      name="Guide Stones"         type="upgrade" hidden="false">
      <rules><rule id="ru-guidestones"      name="Guide Stones"          description="Wraith Sub-type units within 12&quot; of a friendly model with Guide Stones automatically succeed the Wraithsight Leadership test."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-outcastcloaks"    name="Outcast Cloaks"       type="upgrade" hidden="false">
      <rules><rule id="ru-outcastcloaks"    name="Outcast Cloaks"        description="The range between an attacking unit and this unit (if all models have Outcast Cloaks) is considered 6&quot; further than actual. Models with Night Vision or the Primarch Unit Type ignore this. When attacked by Barrage, always treated as out of LoS when scattering."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-bansheemask"      name="Banshee Mask"         type="upgrade" hidden="false">
      <rules><rule id="ru-bansheemask"      name="Banshee Mask"          description="During the Assault phase, the Reactive Player may not make Reactions targeting a unit containing at least one model with a Banshee Mask. Does not activate if the unit makes a Disordered Charge."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-wireweave"        name="Wireweave Net"         type="upgrade" hidden="false">
      <costs><cost name="Pts" typeId="ct-pts" value="5"/></costs>
      <rules><rule id="ru-wireweave"        name="Wireweave Net"          description="The first time this unit is charged in a game, the Opposing Player suffers a -3&quot; penalty to the Charge move distance."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-flipbelt"         name="Flip Belt"            type="upgrade" hidden="false">
      <rules><rule id="ru-flipbelt"         name="Flip Belt"             description="A unit composed entirely of models with Flip Belts may ignore terrain and intervening friendly units while Moving (including Charges, Fall Back, Advancing, and Reactions). Dangerous Terrain tests still apply. Difficult Terrain is entirely ignored."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-maskmanyfaces"    name="The Mask of Many Faces" type="upgrade" hidden="false">
      <rules><rule id="ru-maskmanyfaces"    name="The Mask of Many Faces" description="A unit with at least one model equipped with this mask adds +2 to the Wounds score when determining combat result."/></rules>
    </selectionEntry>
    <selectionEntry id="ge-thirstingmask"    name="The Thirsting Mask"   type="upgrade" hidden="false">
      <rules><rule id="ru-thirstingmask"    name="The Thirsting Mask"    description="This model has Preferred Enemy (Daemons, Corrupted)."/></rules>
    </selectionEntry>
