            <characteristic typeId="ct-m"  name="Move">7</characteristic>
            <characteristic typeId="ct-ws" name="WS">5</characteristic>
            <characteristic typeId="ct-bs" name="BS">5</characteristic>
            <characteristic typeId="ct-s"  name="S">3</characteristic>
            <characteristic typeId="ct-t"  name="T">3</characteristic>
            <characteristic typeId="ct-w"  name="W">2</characteristic>
            <characteristic typeId="ct-i"  name="I">6</characteristic>
