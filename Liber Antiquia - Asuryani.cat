                <selectionEntry id="el-autarch-opt2-shurikpistol" name="Shuriken Pistol (+2 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="2"/></costs><profiles><profile id="pr-autarch2-shurikpistol" name="Shuriken Pistol"  typeId="pt-ranged" profileId="sp-shurikenpistol"/></profiles></selectionEntry>
                <selectionEntry id="el-autarch-opt2-shurikcat"    name="Shuriken Catapult (+5 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="5"/></costs><profiles><profile id="pr-autarch2-shurikcat"    name="Shuriken Catapult" typeId="pt-ranged" profileId="sp-shurikencat"/></profiles></selectionEntry>
                <selectionEntry id="el-autarch-opt2-powersword"   name="Power Weapon (+10 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><profiles><profile id="pr-autarch2-powersword"   name="Power Sword"     typeId="pt-melee"  profileId="sp-powersword"/></profiles></selectionEntry>
                <selectionEntry id="el-autarch-opt2-charnabal"    name="Charnabal Weapon (+10 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="10"/></costs><rules><rule id="ru-autarch2-charnabal" name="Charnabal Weapon" description="May select Charnabal Sabre, Tabar, or Glaive — see Armoury."/></rules></selectionEntry>
                <selectionEntry id="el-autarch-opt2-fusionpistol" name="Fusion Pistol (+15 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="15"/></costs><profiles><profile id="pr-autarch2-fusionpistol" name="Fusion Pistol"    typeId="pt-ranged" profileId="sp-fusionpistol"/></profiles></selectionEntry>
                <selectionEntry id="el-autarch-opt2-starglaive"   name="Star Glaive (+20 pts)"  type="upgrade" hidden="false"><costs><cost name="Pts" typeId="ct-pts" value="20"/></costs><profiles><profile id="pr-autarch2-starglaive"   name="Star Glaive"     typeId="pt-melee"  profileId="sp-starglaive"/></profiles></selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
            <!-- World-Rune selection — 0-1 per detachment, see shared entries -->
