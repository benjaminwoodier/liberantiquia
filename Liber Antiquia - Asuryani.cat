        <profile id="pr-doomweaver-d" name="Doomweaver (Dispersed)" typeId="pt-ranged" profileId="sp-doomweaver-d"/>
        <profile id="pr-doomweaver-f" name="Doomweaver (Focused)"   typeId="pt-ranged" profileId="sp-doomweaver-f"/>
