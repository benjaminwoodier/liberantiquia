  <sharedSelectionEntries>
    <selectionEntry id="saed-ge-holosuit"        name="Holo-Suit"          type="upgrade" hidden="false"><rules><rule id="saed-ru-holosuit"        name="Holo-Suit"          description="Confers a 4+ Invulnerable Save."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-flipbelt"         name="Flip Belt"          type="upgrade" hidden="false"><rules><rule id="saed-ru-flipbelt"         name="Flip Belt"          description="A unit entirely of models with Flip Belts ignores terrain and friendly units while Moving (including Charges, Fall Backs, Advances, and Reactions). Dangerous Terrain tests still apply. Difficult Terrain is entirely ignored."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-holofields"       name="Holo-Fields"        type="upgrade" hidden="false"><rules><rule id="saed-ru-holofields"       name="Holo-Fields"        description="Confers a 5+ Invulnerable Save against Shooting Attacks unless Immobilised."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-miragelaunch"     name="Mirage Launchers"   type="upgrade" hidden="false"><rules><rule id="saed-ru-miragelaunch"     name="Mirage Launchers"   description="Range between an attacking unit and this unit is considered 6&quot; further than actual. Primarch Unit Type models ignore this. Always treated as out of LoS when Barrage attacks scatter."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-maskmanyfaces"    name="The Mask of Many Faces" type="upgrade" hidden="false"><rules><rule id="saed-ru-maskmanyfaces" name="The Mask of Many Faces" description="A unit with this mask adds +2 to the Wounds score when determining combat result."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-thirstingmask"    name="The Thirsting Mask" type="upgrade" hidden="false"><rules><rule id="saed-ru-thirstingmask"    name="The Thirsting Mask" description="This model has Preferred Enemy (Daemons, Corrupted)."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-plasmagrenades"   name="Plasma Grenades"    type="upgrade" hidden="false"><rules><rule id="saed-ru-plasmagrenades"   name="Plasma Grenades"    description="This unit attacks at normal Initiative after charging through Difficult or Dangerous Terrain. May inflict automatic Str 5, AP 4 Hit with Breaching (6+) at Initiative Step 1 against Vehicles, Dreadnoughts, Automata, Buildings, or Fortifications instead of attacking normally."/></rules></selectionEntry>
    <selectionEntry id="saed-ge-haywiregren"      name="Haywire Grenades"   type="upgrade" hidden="false"><profiles><profile id="saed-pr-haywiregren" name="Haywire Grenade (Melee)" typeId="saed-pt-melee" profileId="saed-sp-haywiregrenm"/></profiles></selectionEntry>
    <selectionEntry id="saed-ge-vortexgrenade"    name="Vortex Grenade (+25 pts)" type="upgrade" hidden="false"><costs><cost name="Pts" typeId="saed-ct-pts" value="25"/></costs><profiles><profile id="saed-pr-vortexgrenade" name="Vortex Grenade" typeId="saed-pt-ranged" profileId="saed-sp-vortexgrenade"/></profiles></selectionEntry>
    <selectionEntry id="saed-ge-skyweaverjetbike" name="Skyweaver Jetbike"  type="upgrade" hidden="false">
      <rules><rule id="saed-ru-skyweaverjetbike" name="Skyweaver Jetbike" description="Has Shuriken Cannon. At the start of the Charge Sub-Phase, may move up to unmodified Initiative instead of declaring a Charge. Changes Unit Type to Cavalry (Antigrav), Move to 18. Grants: Fleet (2), Firing Protocols (2), Hit and Run, Hammer of Wrath (1), Relentless, Battle-Hardened (1), Shrouded (5+), Deep Strike."/></rules>
      <profiles><profile id="saed-pr-skyw-can" name="Skyweaver Jetbike (Shuriken Cannon)" typeId="saed-pt-ranged" profileId="saed-sp-shurikencan"/></profiles>
    </selectionEntry>
    <selectionEntry id="saed-ge-starweaverskimmer" name="Starweaver Skimmer" type="upgrade" hidden="false">
      <rules><rule id="saed-ru-starweaverskimmer" name="Starweaver Skimmer" description="Has 2 Shuriken Cannons. At the start of the Charge Sub-Phase, may move up to unmodified Initiative instead of declaring a Charge. Changes Unit Type to Cavalry (Antigrav), Move to 16, gains 3+ Armour Save. Grants: Fleet (2), Firing Protocols (2), Hit and Run, Hammer of Wrath (1), Relentless, Shrouded (5+), Deep Strike."/></rules>
      <profiles>
        <profile id="saed-pr-stw-can1" name="Starweaver Skimmer (Shuriken Cannon 1)" typeId="saed-pt-ranged" profileId="saed-sp-shurikencan"/>
        <profile id="saed-pr-stw-can2" name="Starweaver Skimmer (Shuriken Cannon 2)" typeId="saed-pt-ranged" profileId="saed-sp-shurikencan"/>
      </profiles>
    </selectionEntry>
  </sharedSelectionEntries>

