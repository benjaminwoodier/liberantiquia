<forceEntries>
    <forceEntry id="saed-fe-trialskhaine" name="Grand Performance: The Trials of Khaine" hidden="false">
      <rules><rule id="saed-ru-tok" name="The Trials of Khaine" description="All units gain The Bloodied Blade and Amateur Performance. THE BLOODIED BLADE: At end of game, if 3+ units destroyed in Assault Phase by Rillietann units, gain +D3 VPs. AMATEUR PERFORMANCE: If none destroyed in Assault Phase by Rillietann units, opponent gains +D3 VPs."/></rules>
      <categoryLinks>
        <categoryLink id="saed-fl-tok-hq" targetId="saed-cat-hq" name="HQ" primary="false"><constraints><constraint id="saed-fl-tok-hq-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-tok-hq-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-tok-el" targetId="saed-cat-elites" name="Elites (0-2)" primary="false"><constraints><constraint id="saed-fl-tok-el-max" type="max" value="2" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-tok-tr" targetId="saed-cat-troops" name="Troops (min 2)" primary="false"><constraints><constraint id="saed-fl-tok-tr-min" type="min" value="2" field="selections" scope="force" shared="true"/><constraint id="saed-fl-tok-tr-max" type="max" value="4" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-tok-fa" targetId="saed-cat-fa" name="Fast Attack (0-1)" primary="false"><constraints><constraint id="saed-fl-tok-fa-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-tok-hs" targetId="saed-cat-hs" name="Heavy Support (0-1)" primary="false"><constraints><constraint id="saed-fl-tok-hs-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
      </categoryLinks>
    </forceEntry>
    <forceEntry id="saed-fe-heroespath" name="Grand Performance: The Heroes Path" hidden="false">
      <rules><rule id="saed-ru-hp" name="The Heroes Path" description="All units gain The Sin of Pride and Amateur Performance. THE SIN OF PRIDE: All Character Sub-type models must issue or accept any Challenge possible. At end of game, if 3+ models destroyed in Challenges by Character models, gain +D3 VPs. AMATEUR PERFORMANCE: If none destroyed in Challenges, opponent gains +D3 VPs."/></rules>
      <categoryLinks>
        <categoryLink id="saed-fl-hp-hq" targetId="saed-cat-hq" name="HQ (min 2)" primary="false"><constraints><constraint id="saed-fl-hp-hq-min" type="min" value="2" field="selections" scope="force" shared="true"/><constraint id="saed-fl-hp-hq-max" type="max" value="2" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-hp-el" targetId="saed-cat-elites" name="Elites (min 1 Shadowseer)" primary="false"><constraints><constraint id="saed-fl-hp-el-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-hp-el-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-hp-tr" targetId="saed-cat-troops" name="Troops (min 2)" primary="false"><constraints><constraint id="saed-fl-hp-tr-min" type="min" value="2" field="selections" scope="force" shared="true"/><constraint id="saed-fl-hp-tr-max" type="max" value="4" field="selections" scope="force" shared="true"/></constraints></categoryLink>
      </categoryLinks>
    </forceEntry>
    <forceEntry id="saed-fe-cegorjest" name="Grand Performance: Cegorach's Jest" hidden="false">
      <rules><rule id="saed-ru-cj" name="Cegorach's Jest" description="All units gain The Last Laugh and Amateur Performance. THE LAST LAUGH: At end of game, gain +D3 VPs if 3+ Starweavers, Voidweavers, or Skyweaver units (any combination) are in the opponent's Deployment Zone. AMATEUR PERFORMANCE: If none are there, opponent gains +D3 VPs."/></rules>
      <categoryLinks>
        <categoryLink id="saed-fl-cj-hq" targetId="saed-cat-hq" name="HQ (min 1)" primary="false"><constraints><constraint id="saed-fl-cj-hq-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-cj-hq-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cj-el" targetId="saed-cat-elites" name="Elites (0-2)" primary="false"><constraints><constraint id="saed-fl-cj-el-max" type="max" value="2" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cj-tr" targetId="saed-cat-troops" name="Troops (0-3)" primary="false"><constraints><constraint id="saed-fl-cj-tr-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cj-fa" targetId="saed-cat-fa" name="Fast Attack (min 1)" primary="false"><constraints><constraint id="saed-fl-cj-fa-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-cj-fa-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cj-hs" targetId="saed-cat-hs" name="Heavy Support (min 1)" primary="false"><constraints><constraint id="saed-fl-cj-hs-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-cj-hs-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
      </categoryLinks>
    </forceEntry>
    <forceEntry id="saed-fe-cegorlament" name="Grand Performance: Cegorach's Lament" hidden="false">
      <rules><rule id="saed-ru-cl" name="Cegorach's Lament" description="Cannot be selected with a Traitor Allegiance Detachment. All units gain The Curtain Falls and Amateur Performance. THE CURTAIN FALLS: At end of game, if 3+ Daemon/Daemon Primarch/Corrupted units destroyed by Rillietann units, gain +D3+1 VPs. If the Arebennian slays the enemy Warlord, gain +2 additional VPs. AMATEUR PERFORMANCE: If no VPs scored from The Curtain Falls, opponent gains +D3 VPs."/></rules>
      <categoryLinks>
        <categoryLink id="saed-fl-cl-hq" targetId="saed-cat-hq" name="HQ (min 1)" primary="false"><constraints><constraint id="saed-fl-cl-hq-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-cl-hq-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cl-el" targetId="saed-cat-elites" name="Elites (min 1 Arebennian)" primary="false"><constraints><constraint id="saed-fl-cl-el-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-cl-el-max" type="max" value="4" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cl-tr" targetId="saed-cat-troops" name="Troops (min 1)" primary="false"><constraints><constraint id="saed-fl-cl-tr-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-cl-tr-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cl-fa" targetId="saed-cat-fa" name="Fast Attack (0-1)" primary="false"><constraints><constraint id="saed-fl-cl-fa-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-cl-hs" targetId="saed-cat-hs" name="Heavy Support (0-2)" primary="false"><constraints><constraint id="saed-fl-cl-hs-max" type="max" value="2" field="selections" scope="force" shared="true"/></constraints></categoryLink>
      </categoryLinks>
    </forceEntry>
    <forceEntry id="saed-fe-faolchublade" name="Grand Performance: Faolchu's Blade" hidden="false">
      <rules><rule id="saed-ru-fb" name="Faolchu's Blade" description="All Infantry must begin Embarked on a Transport. All units gain The Falcon's Wing and Amateur Performance. THE FALCON'S WING: Before game, count Primary Detachment Independent Characters. At end of game, if at least half are still in play AND at least one Rillietann unit with this rule is still in play, gain +D3+1 VPs. AMATEUR PERFORMANCE: If no VPs scored from The Falcon's Wing, opponent gains +D3 VPs."/></rules>
      <categoryLinks>
        <categoryLink id="saed-fl-fb-hq" targetId="saed-cat-hq" name="HQ (min 1)" primary="false"><constraints><constraint id="saed-fl-fb-hq-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-fb-hq-max" type="max" value="1" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-fb-el" targetId="saed-cat-elites" name="Elites (0-2)" primary="false"><constraints><constraint id="saed-fl-fb-el-max" type="max" value="2" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-fb-tr" targetId="saed-cat-troops" name="Troops (min 1)" primary="false"><constraints><constraint id="saed-fl-fb-tr-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-fb-tr-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-fb-fa" targetId="saed-cat-fa" name="Fast Attack (min 1)" primary="false"><constraints><constraint id="saed-fl-fb-fa-min" type="min" value="1" field="selections" scope="force" shared="true"/><constraint id="saed-fl-fb-fa-max" type="max" value="3" field="selections" scope="force" shared="true"/></constraints></categoryLink>
        <categoryLink id="saed-fl-fb-hs" targetId="saed-cat-hs" name="Heavy Support (0-2)" primary="false"><constraints><constraint id="saed-fl-fb-hs-max" type="max" value="2" field="selections" scope="force" shared="true"/></constraints></categoryLink>
      </categoryLinks>
    </forceEntry>
  </forceEntries>

<sharedRules>
    <rule id="saed-sr-rillietype"    name="Rillietann Sub-type"       description="Models with this Sub-type have Fear (1), Move Through Cover, Hit and Run, and Furious Charge (1). May only be taken in a Saedathii Detachment. Independent Characters with this Sub-type may only join units which also have the Rillietann Sub-type."/>
    <rule id="saed-sr-fleet2"        name="Fleet (2)"                 description="This unit may re-roll up to two dice when determining Run or Charge distance."/>
    <rule id="saed-sr-fleet3"        name="Fleet (3)"                 description="This unit may re-roll up to three dice when determining Run or Charge distance."/>
    <rule id="saed-sr-ic"            name="Independent Character"     description="This model may join and leave units as per the Independent Character rules in the core rulebook."/>
    <rule id="saed-sr-stubborn"      name="Stubborn"                  description="This unit uses its unmodified Leadership when making Morale checks."/>
    <rule id="saed-sr-fear2"         name="Fear (2)"                  description="Enemy units in base contact must pass a Leadership test at -2 or suffer -1 WS for the Assault phase."/>
    <rule id="saed-sr-hitrun"        name="Hit and Run"               description="This unit may make a Hit and Run move as per the core rulebook."/>
    <rule id="saed-sr-furcharge1"    name="Furious Charge (1)"        description="This unit gains +1 Strength on a turn in which it charges."/>
    <rule id="saed-sr-furcharge2"    name="Furious Charge (2)"        description="This unit gains +2 Strength on a turn in which it charges."/>
    <rule id="saed-sr-relentless"    name="Relentless"                description="This unit may fire Heavy or Ordnance weapons counting as Stationary even if it moved."/>
    <rule id="saed-sr-deepstrike"    name="Deep Strike"               description="This unit may be held in Reserve and arrive via Deep Strike Assault."/>
    <rule id="saed-sr-shroud5"       name="Shrouded (5+)"             description="Models may take a 5+ Damage Mitigation roll against any Wound or Hull Point of damage."/>
    <rule id="saed-sr-shroud4"       name="Shrouded (4+)"             description="Models may take a 4+ Damage Mitigation roll against any Wound or Hull Point of damage."/>
    <rule id="saed-sr-mtc"           name="Move Through Cover"        description="Roll an extra D6 and discard the lowest when moving through Difficult Terrain."/>
    <rule id="saed-sr-infiltrate"    name="Infiltrate"                description="May be set up using Infiltrate deployment rules."/>
    <rule id="saed-sr-pathfinder"    name="Pathfinder"                description="This unit treats all Difficult Terrain as Open Terrain when moving."/>
    <rule id="saed-sr-chosenw"       name="Chosen Warriors"           description="This unit may use the Leadership of any model in the unit when taking Leadership tests."/>
    <rule id="saed-sr-precshots4"    name="Precision Shots (4+)"      description="On a To-Hit roll of 4+, shooting attacks may be allocated to any model in the target unit."/>
    <rule id="saed-sr-precshots6"    name="Precision Shots (6+)"      description="On a To-Hit roll of 6+, shooting attacks may be allocated to any model in the target unit."/>
    <rule id="saed-sr-precstrikes5"  name="Precision Strikes (5+)"    description="On a To-Hit roll of 5+, melee attacks may be allocated to any model in the target unit."/>
    <rule id="saed-sr-precstrikes6"  name="Precision Strikes (6+)"    description="On a To-Hit roll of 6+, melee attacks may be allocated to any model in the target unit."/>
    <rule id="saed-sr-splitfire"     name="Split Fire"                description="One model in this unit may target a different unit when shooting."/>
    <rule id="saed-sr-hamwrath1"     name="Hammer of Wrath (1)"       description="Each model makes 1 additional automatic hit at unmodified Strength with no AP when making a successful Charge."/>
    <rule id="saed-sr-firingp2"      name="Firing Protocols (2)"      description="Once per turn, this model may fire a second time with a single Assault or Pistol weapon at BS 1."/>
    <rule id="saed-sr-firingp3"      name="Firing Protocols (3)"      description="Once per turn, this model may fire up to two additional times with Assault or Pistol weapons at BS 1."/>
    <rule id="saed-sr-bh1"           name="Battle-Hardened (1)"       description="This unit may re-roll a single To Hit roll per phase."/>
    <rule id="saed-sr-skilledrider"  name="Skilled Rider"             description="May run in the Movement Phase and still fire a single ranged weapon in the Shooting Phase at BS2. Cannot be improved. Cannot combine with Firing Protocols (X) in the same turn."/>
    <rule id="saed-sr-harrowlord"    name="Harrow-Lord"               description="Any unit from which a model is removed as a casualty in the Shooting Phase by this model must take a Morale check as if they had suffered 25% casualties."/>
    <rule id="saed-sr-agentpand"     name="Agent of Pandemonium"      description="This model gains the Phantasmancy, Thaumaturgy, and Telepathy Psychic Disciplines. See Liber Antiquia p.110 and core rulebook p.322."/>
    <rule id="saed-sr-soulforfeit"   name="Soul Forfeit"              description="This model never awards Victory Points when slain, does not count toward units slain, and is not a Scoring or Denial unit."/>
    <rule id="saed-sr-psym1"         name="Psychic Mastery (1)"       description="This model may cast up to 1 Psychic Power per phase."/>
    <rule id="saed-sr-opentop6"      name="Open-Topped (6)"           description="Up to 6 embarked models may make Shooting Attacks measuring from the Transport hull, counting as having moved. +1 to Vehicle Damage Table rolls against this model."/>
    <rule id="saed-sr-transportskiff" name="Transport Skiff"          description="Gains Infantry Transport and Assault Vehicle rules, counts as a Vehicle for Transport purposes. When destroyed, all embarked models suffer S6 AP- hits allocated by the Controlling Player. Survivors placed in coherency 1&quot; from enemies; those that cannot are removed. Unit takes a Pinning test."/>
    <rule id="saed-sr-phantasmancy"  name="Psychic Discipline: Phantasmancy" description="VEIL OF TEARS: During the Movement Phase, select an enemy unit within 24&quot; and LoS. It may not Shoot at Rillietann units over 18&quot; until the start of your next turn. Optional Psychic Check: if passed, it also may not React against Rillietann units until the end of the Opposing Player's next turn. If failed, no effect and suffer Perils. PEAL OF DISCORD (Psychic Weapon): 24&quot;, Str 4, AP -, Assault 4, Blind, Psychic Focus."/>
    <rule id="saed-sr-counter1"      name="Counter-Attack (1)"        description="If this unit is charged, it may make 1 additional attack in the ensuing Assault phase."/>
  </sharedRules>

  <sharedProfiles>
    <profile id="saed-sp-shurikenpistol"   name="Shuriken Pistol"              typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">12&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">4</characteristic><characteristic typeId="saed-ct-rap" name="AP">5</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Pistol 1, Breaching (6+)</characteristic></characteristics></profile>
    <profile id="saed-sp-neurodisruptor"   name="Neuro Disruptor"              typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">12&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">1</characteristic><characteristic typeId="saed-ct-rap" name="AP">2</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Pistol 1, Fleshbane</characteristic></characteristics></profile>
    <profile id="saed-sp-fusionpistol"     name="Fusion Pistol"                typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">8&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">8</characteristic><characteristic typeId="saed-ct-rap" name="AP">1</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Pistol 1, Armourbane (Melta)</characteristic></characteristics></profile>
    <profile id="saed-sp-shriekercannon-a" name="Shrieker Cannon (Shuriken Volley)"    typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">24&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">6</characteristic><characteristic typeId="saed-ct-rap" name="AP">5</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Assault 4, Breaching (5+)</characteristic></characteristics></profile>
    <profile id="saed-sp-shriekercannon-b" name="Shrieker Cannon (Shrieker Fusillade)" typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">24&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">1</characteristic><characteristic typeId="saed-ct-rap" name="AP">5</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Assault 1, Rending (5+), Poisoned (2+), Bio-Explosive</characteristic></characteristics></profile>
    <profile id="saed-sp-aml-sunburst"     name="Aeldari Missile Launcher (Sunburst)"  typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">48&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">4</characteristic><characteristic typeId="saed-ct-rap" name="AP">4</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Heavy 1, Blast (3&quot;), Blind</characteristic></characteristics></profile>
    <profile id="saed-sp-aml-starshot"     name="Aeldari Missile Launcher (Starshot)"  typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">48&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">8</characteristic><characteristic typeId="saed-ct-rap" name="AP">3</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Heavy 1</characteristic></characteristics></profile>
    <profile id="saed-sp-brightlance"      name="Bright Lance"                 typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">36&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">8</characteristic><characteristic typeId="saed-ct-rap" name="AP">2</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Heavy 1, Lance, Sunder</characteristic></characteristics></profile>
    <profile id="saed-sp-firepike"         name="Fire Pike"                    typeId="saed-pt-ranged"><characteristics><characteristic typeId="saed-ct-rng" name="Range">18&quot;</characteristic><characteristic typeId="saed-ct-rstr" name="Str">9</characteristic><characteristic typeId="saed-ct-rap" name="AP">1</characteristic><characteristic typeId="saed-ct-rtyp" name="Type">Assault 1, Armourbane (Melta)</characteristic></characteristics></profile>
